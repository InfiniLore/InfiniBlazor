        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
    </PropertyGroup>

    <ItemGroup>
        <InternalsVisibleTo Include="InfiniBlazorTests" />
        <InternalsVisibleTo Include="InfiniBlazorTests.Core.Markdown" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\src\InfiniBlazor\InfiniBlazor.csproj" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="CodeOfChaos.Extensions" />
