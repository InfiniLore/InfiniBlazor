  <MdTestData Id="quotedLine" FileName="escaped_char.xml">
    <MdString>\"She told me that \'he isn't here right *now*\' - so I left.\"</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <EscapedCharacterMdSyntaxNode xml:space="preserve">"</EscapedCharacterMdSyntaxNode>
        <TextMdSyntaxNode xml:space="preserve">She told me that </TextMdSyntaxNode>
        <EscapedCharacterMdSyntaxNode xml:space="preserve">'</EscapedCharacterMdSyntaxNode>
        <TextMdSyntaxNode xml:space="preserve">he isn't here right </TextMdSyntaxNode>
        <ItalicMdSyntaxNode>
          <TextMdSyntaxNode xml:space="preserve">now</TextMdSyntaxNode>
        </ItalicMdSyntaxNode>
        <EscapedCharacterMdSyntaxNode xml:space="preserve">'</EscapedCharacterMdSyntaxNode>
        <TextMdSyntaxNode xml:space="preserve"> - so I left.</TextMdSyntaxNode>
        <EscapedCharacterMdSyntaxNode xml:space="preserve">"</EscapedCharacterMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedMarkdown>\"She told me that \'he isn't here right *now*\' - so I left.\"</ExpectedMarkdown>
    <ExpectedJsonString>{
  "type": "MdSyntaxTree",
  "children": [
    {
      "type": "ParagraphMdSyntaxNode",
      "children": [
        {
          "type": "EscapedCharacterMdSyntaxNode",
          "content": "\""
        },
        {
          "type": "TextMdSyntaxNode",
          "content": "She told me that "
        },
        {
          "type": "EscapedCharacterMdSyntaxNode",
          "content": "'"
        },
        {
          "type": "TextMdSyntaxNode",
          "content": "he isn't here right "
        },
        {
          "type": "ItalicMdSyntaxNode",
          "children": [
            {
              "type": "TextMdSyntaxNode",
              "content": "now"
            }
          ]
        },
        {
          "type": "EscapedCharacterMdSyntaxNode",
          "content": "'"
        },
        {
          "type": "TextMdSyntaxNode",
          "content": " - so I left."
        },
        {
          "type": "EscapedCharacterMdSyntaxNode",
          "content": "\""
        }
      ]
    }
  ]
}</ExpectedJsonString>
  </MdTestData>
