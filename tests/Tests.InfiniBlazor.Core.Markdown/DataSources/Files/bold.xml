  <MdTestData Id="default" FileName="bold.xml">
    <MdString>**bold**</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <BoldMdSyntaxNode>
          <TextMdSyntaxNode xml:space="preserve">bold</TextMdSyntaxNode>
        </BoldMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlString>&lt;p&gt;&lt;strong&gt;bold&lt;/strong&gt;&lt;/p&gt;</ExpectedHtmlString>
    <ExpectedMarkdownString>**bold**</ExpectedMarkdownString>
    <ExpectedJsonString>{
  "type": "MdSyntaxTree",
  "children": [
    {
      "type": "ParagraphMdSyntaxNode",
      "children": [
        {
          "type": "BoldMdSyntaxNode",
          "children": [
            {
              "type": "TextMdSyntaxNode",
              "content": "bold"
            }
          ]
        }
      ]
    }
  ]
}</ExpectedJsonString>
  </MdTestData>
