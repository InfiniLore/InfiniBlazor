  <MdTestData Id="withLink" FileName="bold.xml">
    <MdString>**[transgenderinfo](https://www.transgenderinfo.be)**</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <BoldMdSyntaxNode>
          <LinkMdSyntaxNode Href="https://www.transgenderinfo.be">
            <TextMdSyntaxNode xml:space="preserve">transgenderinfo</TextMdSyntaxNode>
          </LinkMdSyntaxNode>
        </BoldMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlString>&lt;p&gt;&lt;strong&gt;&lt;a href="https://www.transgenderinfo.be"&gt;transgenderinfo&lt;/a&gt;&lt;/strong&gt;&lt;/p&gt;</ExpectedHtmlString>
    <ExpectedMarkdownString>**[transgenderinfo](https://www.transgenderinfo.be)**</ExpectedMarkdownString>
    <ExpectedMarkdownStringSkipOnWhitespaceMisMatch>True</ExpectedMarkdownStringSkipOnWhitespaceMisMatch>
    <ExpectedJsonString>{
  "type": "MdSyntaxTree",
  "children": [
    {
      "type": "ParagraphMdSyntaxNode",
      "children": [
        {
          "type": "BoldMdSyntaxNode",
          "children": [
            {
              "type": "LinkMdSyntaxNode",
              "href": "https://www.transgenderinfo.be",
              "children": [
                {
                  "type": "TextMdSyntaxNode",
                  "content": "transgenderinfo"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}</ExpectedJsonString>
  </MdTestData>
