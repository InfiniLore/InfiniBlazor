<?xml version="1.0" encoding="utf-8"?>
<ArrayOfMdTestData xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <MdTestData Id="default" FileName="underline.xml">
    <MdString>_underline_</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <UnderlineMdSyntaxNode>
          <TextMdSyntaxNode xml:space="preserve">underline</TextMdSyntaxNode>
        </UnderlineMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlString>&lt;p class="my-4 leading-relaxed"&gt;&lt;u&gt;underline&lt;/u&gt;&lt;/p&gt;</ExpectedHtmlString>
    <ExpectedMarkdown>_underline_</ExpectedMarkdown>
    <ExpectedMarkdownSkipOnWhitespaceMisMatch>True</ExpectedMarkdownSkipOnWhitespaceMisMatch>
    <ExpectedJsonString>{
  "type": "MdSyntaxTree",
  "children": [
    {
      "type": "ParagraphMdSyntaxNode",
      "children": [
        {
          "type": "UnderlineMdSyntaxNode",
          "children": [
            {
              "type": "TextMdSyntaxNode",
              "content": "underline"
            }
          ]
        }
      ]
    }
  ]
}</ExpectedJsonString>
  </MdTestData>
  <MdTestData Id="edgecaseCodeInlineShouldBeSkipped" FileName="underline.xml">
    <DeveloperNote>Because we traverse the input text from left to right</DeveloperNote>
    <MdString>_ `_`</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <UnderlineMdSyntaxNode>
          <TextMdSyntaxNode xml:space="preserve"> `</TextMdSyntaxNode>
        </UnderlineMdSyntaxNode>
        <TextMdSyntaxNode xml:space="preserve">`</TextMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlString>&lt;p class="my-4 leading-relaxed"&gt;&lt;u&gt; `&lt;/u&gt;`&lt;/p&gt;</ExpectedHtmlString>
    <ExpectedMarkdown>_ `_`</ExpectedMarkdown>
    <ExpectedJsonString>{
  "type": "MdSyntaxTree",
  "children": [
    {
      "type": "ParagraphMdSyntaxNode",
      "children": [
        {
          "type": "UnderlineMdSyntaxNode",
          "children": [
            {
              "type": "TextMdSyntaxNode",
              "content": " `"
            }
          ]
        },
        {
          "type": "TextMdSyntaxNode",
          "content": "`"
        }
      ]
    }
  ]
}</ExpectedJsonString>
  </MdTestData>
  <MdTestData Id="edgecaseShouldBeCaughtByCodeInlines" FileName="underline.xml">
    <MdString>`_` `_`</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <CodeInlineMdSyntaxNode xml:space="preserve" BackTickCount="1">_</CodeInlineMdSyntaxNode>
        <TextMdSyntaxNode xml:space="preserve"> </TextMdSyntaxNode>
        <CodeInlineMdSyntaxNode xml:space="preserve" BackTickCount="1">_</CodeInlineMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlString>&lt;p class="my-4 leading-relaxed"&gt;&lt;code class="infini-bg-(--codeblock) text-(--color-base-20) rounded px-1 font-mono text-sm"&gt;_&lt;/code&gt; &lt;code class="infini-bg-(--codeblock) text-(--color-base-20) rounded px-1 font-mono text-sm"&gt;_&lt;/code&gt;&lt;/p&gt;</ExpectedHtmlString>
    <ExpectedMarkdown>`_` `_`</ExpectedMarkdown>
    <ExpectedJsonString>{
  "type": "MdSyntaxTree",
  "children": [
    {
      "type": "ParagraphMdSyntaxNode",
      "children": [
        {
          "type": "CodeInlineMdSyntaxNode",
          "backTickCount": 1,
          "content": "_"
        },
        {
          "type": "TextMdSyntaxNode",
          "content": " "
        },
        {
          "type": "CodeInlineMdSyntaxNode",
          "backTickCount": 1,
          "content": "_"
        }
      ]
    }
  ]
}</ExpectedJsonString>
  </MdTestData>
