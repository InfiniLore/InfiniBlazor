    <ExpectedJsonString>{
  "type": "MdSyntaxTree",
  "children": [
    {
      "type": "ParagraphMdSyntaxNode",
      "children": [
        {
          "type": "SubScriptMdSyntaxNode",
          "children": [
            {
              "type": "TextMdSyntaxNode",
              "content": "something "
            },
            {
              "type": "BoldMdSyntaxNode",
              "children": [
                {
                  "type": "TextMdSyntaxNode",
                  "content": "bold"
