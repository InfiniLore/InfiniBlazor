<?xml version="1.0" encoding="utf-8"?>
<ArrayOfMdTestData xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <MdTestData Id="default" FileName="superscript.xml">
    <MdString>^superscript^</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <SuperScriptMdSyntaxNode>
          <TextMdSyntaxNode xml:space="preserve">superscript</TextMdSyntaxNode>
        </SuperScriptMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlStringSimplified>&lt;p&gt;&lt;sup&gt;superscript&lt;/sup&gt;&lt;/p&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>^superscript^</ExpectedMarkdownString>
  </MdTestData>
  <MdTestData Id="edgecaseUnbound" FileName="superscript.xml">
    <MdString>^superscript</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <TextMdSyntaxNode xml:space="preserve">^superscript</TextMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlStringSimplified>&lt;p&gt;^superscript&lt;/p&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>^superscript</ExpectedMarkdownString>
  </MdTestData>
  <MdTestData Id="empty" FileName="superscript.xml">
    <MdString>^^</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <TextMdSyntaxNode xml:space="preserve">^^</TextMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlStringSimplified>&lt;p&gt;^^&lt;/p&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>^^</ExpectedMarkdownString>
  </MdTestData>
  <MdTestData Id="withBold" FileName="superscript.xml">
    <MdString>^something **bold** in superscript^</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <SuperScriptMdSyntaxNode>
          <TextMdSyntaxNode xml:space="preserve">something </TextMdSyntaxNode>
          <BoldMdSyntaxNode>
            <TextMdSyntaxNode xml:space="preserve">bold</TextMdSyntaxNode>
          </BoldMdSyntaxNode>
          <TextMdSyntaxNode xml:space="preserve"> in superscript</TextMdSyntaxNode>
        </SuperScriptMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlStringSimplified>&lt;p&gt;&lt;sup&gt;something &lt;strong&gt;bold&lt;/strong&gt; in superscript&lt;/sup&gt;&lt;/p&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>^something **bold** in superscript^</ExpectedMarkdownString>
  </MdTestData>
  <MdTestData Id="withBoldAndEscapedObelix_1" FileName="superscript.xml">
    <MdString>^superscript **nested \^^ bold**^</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <SuperScriptMdSyntaxNode>
          <TextMdSyntaxNode xml:space="preserve">superscript **nested </TextMdSyntaxNode>
          <EscapedCharacterMdSyntaxNode xml:space="preserve">^</EscapedCharacterMdSyntaxNode>
        </SuperScriptMdSyntaxNode>
        <TextMdSyntaxNode xml:space="preserve"> bold**^</TextMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlStringSimplified>&lt;p&gt;&lt;sup&gt;superscript **nested ^&lt;/sup&gt; bold**^&lt;/p&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>^superscript **nested \^^ bold**^</ExpectedMarkdownString>
  </MdTestData>
  <MdTestData Id="withEscapedObelix_1" FileName="superscript.xml">
    <MdString>\^superscript^</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <EscapedCharacterMdSyntaxNode xml:space="preserve">^</EscapedCharacterMdSyntaxNode>
        <TextMdSyntaxNode xml:space="preserve">superscript^</TextMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlStringSimplified>&lt;p&gt;^superscript^&lt;/p&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>\^superscript^</ExpectedMarkdownString>
  </MdTestData>
  <MdTestData Id="withEscapedObelix_2" FileName="superscript.xml">
    <MdString>^superscript\^</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <TextMdSyntaxNode xml:space="preserve">^superscript</TextMdSyntaxNode>
        <EscapedCharacterMdSyntaxNode xml:space="preserve">^</EscapedCharacterMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlStringSimplified>&lt;p&gt;^superscript^&lt;/p&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>^superscript\^</ExpectedMarkdownString>
  </MdTestData>
  <MdTestData Id="withEscapedObelix_3" FileName="superscript.xml">
    <MdString>^ \^ ^</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <SuperScriptMdSyntaxNode>
          <TextMdSyntaxNode xml:space="preserve"> </TextMdSyntaxNode>
          <EscapedCharacterMdSyntaxNode xml:space="preserve">^</EscapedCharacterMdSyntaxNode>
          <TextMdSyntaxNode xml:space="preserve"> </TextMdSyntaxNode>
        </SuperScriptMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlStringSimplified>&lt;p&gt;&lt;sup&gt; ^ &lt;/sup&gt;&lt;/p&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>^ \^ ^</ExpectedMarkdownString>
  </MdTestData>
  <MdTestData Id="withEscapedObelix_4" FileName="superscript.xml">
    <MdString>\^literal little hats\^</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <EscapedCharacterMdSyntaxNode xml:space="preserve">^</EscapedCharacterMdSyntaxNode>
        <TextMdSyntaxNode xml:space="preserve">literal little hats</TextMdSyntaxNode>
        <EscapedCharacterMdSyntaxNode xml:space="preserve">^</EscapedCharacterMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlStringSimplified>&lt;p&gt;^literal little hats^&lt;/p&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>\^literal little hats\^</ExpectedMarkdownString>
  </MdTestData>
  <MdTestData Id="withTag" FileName="superscript.xml">
    <MdString>^#tag^</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <SuperScriptMdSyntaxNode>
          <TagMdSyntaxNode xml:space="preserve">tag</TagMdSyntaxNode>
        </SuperScriptMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlStringSimplified>&lt;p&gt;&lt;sup&gt;&lt;span class="md-tag"&gt;#tag&lt;/span&gt;&lt;/sup&gt;&lt;/p&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>^#tag^</ExpectedMarkdownString>
  </MdTestData>
</ArrayOfMdTestData>