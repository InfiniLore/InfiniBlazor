  <MdTestData Id="withBold" FileName="italic.xml">
    <MdString>*something **bold** in italic*</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <ItalicMdSyntaxNode>
          <TextMdSyntaxNode xml:space="preserve">something </TextMdSyntaxNode>
          <BoldMdSyntaxNode>
            <TextMdSyntaxNode xml:space="preserve">bold</TextMdSyntaxNode>
          </BoldMdSyntaxNode>
          <TextMdSyntaxNode xml:space="preserve"> in italic</TextMdSyntaxNode>
        </ItalicMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlString>&lt;p&gt;&lt;em&gt;something &lt;strong&gt;bold&lt;/strong&gt; in italic&lt;/em&gt;&lt;/p&gt;</ExpectedHtmlString>
    <ExpectedMarkdownString>*something **bold** in italic*</ExpectedMarkdownString>
    <ExpectedJsonString>{
  "type": "MdSyntaxTree",
  "children": [
    {
      "type": "ParagraphMdSyntaxNode",
      "children": [
        {
          "type": "ItalicMdSyntaxNode",
          "children": [
            {
              "type": "TextMdSyntaxNode",
              "content": "something "
            },
            {
              "type": "BoldMdSyntaxNode",
              "children": [
                {
                  "type": "TextMdSyntaxNode",
                  "content": "bold"
                }
              ]
            },
            {
              "type": "TextMdSyntaxNode",
              "content": " in italic"
            }
          ]
        }
      ]
    }
  ]
}</ExpectedJsonString>
  </MdTestData>
