  <MdTestData Id="description_withBold" FileName="footnote.xml">
    <MdString>test [^1]

[^1] : some **content** in description
</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <TextMdSyntaxNode xml:space="preserve">test </TextMdSyntaxNode>
        <FootnoteReferenceMdSyntaxNode Identifier="1" />
      </ParagraphMdSyntaxNode>
      <NewLineMdSyntaxNode />
      <NewLineMdSyntaxNode />
      <FootnoteDescriptionMdSyntaxNode Identifier="1">
        <ParagraphMdSyntaxNode>
          <TextMdSyntaxNode xml:space="preserve">some </TextMdSyntaxNode>
          <BoldMdSyntaxNode>
            <TextMdSyntaxNode xml:space="preserve">content</TextMdSyntaxNode>
          </BoldMdSyntaxNode>
          <TextMdSyntaxNode xml:space="preserve"> in description</TextMdSyntaxNode>
        </ParagraphMdSyntaxNode>
      </FootnoteDescriptionMdSyntaxNode>
      <NewLineMdSyntaxNode />
    </MdSyntaxTree>
