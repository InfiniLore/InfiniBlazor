        <ParagraphMdSyntaxNode>
          <TextMdSyntaxNode xml:space="preserve">paragraph 1</TextMdSyntaxNode>
        </ParagraphMdSyntaxNode>
        <NewLineMdSyntaxNode />
        <ParagraphMdSyntaxNode>
          <TextMdSyntaxNode xml:space="preserve">paragraph 2</TextMdSyntaxNode>
