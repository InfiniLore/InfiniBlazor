      <ParagraphMdSyntaxNode>
        <TextMdSyntaxNode xml:space="preserve">test </TextMdSyntaxNode>
        <FootnoteReferenceMdSyntaxNode Identifier="1" />
      </ParagraphMdSyntaxNode>
