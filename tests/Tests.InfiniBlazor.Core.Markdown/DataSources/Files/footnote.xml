  <MdTestData Id="default" FileName="footnote.xml">
    <MdString>test [^1]</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <TextMdSyntaxNode xml:space="preserve">test </TextMdSyntaxNode>
        <FootnoteReferenceMdSyntaxNode Identifier="1" />
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlStringSimplified>&lt;p&gt;test &lt;/p&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>test [^1]</ExpectedMarkdownString>
  </MdTestData>
  <MdTestData Id="default_withDescription" FileName="footnote.xml">
