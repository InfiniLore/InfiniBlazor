  <MdTestData Id="invalid" FileName="tag.xml">
    <MdString>#this is not a valid tag

#[link](https://www.transgenderinfo.be)</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <TagMdSyntaxNode xml:space="preserve">this</TagMdSyntaxNode>
        <TextMdSyntaxNode xml:space="preserve"> is not a valid tag</TextMdSyntaxNode>
      </ParagraphMdSyntaxNode>
      <NewLineMdSyntaxNode />
      <NewLineMdSyntaxNode />
      <ParagraphMdSyntaxNode>
        <TextMdSyntaxNode xml:space="preserve">#</TextMdSyntaxNode>
        <LinkMdSyntaxNode Href="https://www.transgenderinfo.be">
          <TextMdSyntaxNode xml:space="preserve">link</TextMdSyntaxNode>
        </LinkMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlString>&lt;p class="my-4 leading-relaxed"&gt;&lt;span class="inline-block px-2 py-0.5 rounded-full leading-4 infini-bg-(--color-base-90) text-(--color-accent)"&gt;this&lt;/span&gt; is not a valid tag&lt;/p&gt;&lt;p class="my-4 leading-relaxed"&gt;#&lt;a href="https://www.transgenderinfo.be" class="text-(--color-accent) hover:text-(--color-accent-light) hover:underline"&gt;link&lt;/a&gt;&lt;/p&gt;</ExpectedHtmlString>
    <ExpectedMarkdownString>#this is not a valid tag

#[link](https://www.transgenderinfo.be)</ExpectedMarkdownString>
    <ExpectedMarkdownStringSkipOnWhitespaceMisMatch>True</ExpectedMarkdownStringSkipOnWhitespaceMisMatch>
    <ExpectedJsonString>{
  "type": "MdSyntaxTree",
  "children": [
    {
      "type": "ParagraphMdSyntaxNode",
      "children": [
        {
          "type": "TagMdSyntaxNode",
          "content": "this"
        },
        {
          "type": "TextMdSyntaxNode",
          "content": " is not a valid tag"
        }
      ]
    },
    {
      "type": "NewLineMdSyntaxNode"
    },
    {
      "type": "NewLineMdSyntaxNode"
    },
    {
      "type": "ParagraphMdSyntaxNode",
      "children": [
        {
          "type": "TextMdSyntaxNode",
          "content": "#"
        },
        {
          "type": "LinkMdSyntaxNode",
          "href": "https://www.transgenderinfo.be",
          "children": [
            {
              "type": "TextMdSyntaxNode",
              "content": "link"
            }
          ]
        }
      ]
    }
  ]
}</ExpectedJsonString>
  </MdTestData>
