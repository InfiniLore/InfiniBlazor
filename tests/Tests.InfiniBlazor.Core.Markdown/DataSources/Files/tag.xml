<?xml version="1.0" encoding="utf-8"?>
<ArrayOfMdTestData xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <MdTestData Id="default" FileName="tag.xml">
    <MdString>#tag</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <TagMdSyntaxNode xml:space="preserve">tag</TagMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlString>&lt;p&gt;&lt;span class="md-tag"&gt;#tag&lt;/span&gt;&lt;/p&gt;</ExpectedHtmlString>
    <ExpectedMarkdownString>#tag</ExpectedMarkdownString>
    <ExpectedMarkdownStringSkipOnWhitespaceMisMatch>True</ExpectedMarkdownStringSkipOnWhitespaceMisMatch>
    <ExpectedJsonString>{
  "type": "MdSyntaxTree",
  "children": [
    {
      "type": "ParagraphMdSyntaxNode",
      "children": [
        {
          "type": "TagMdSyntaxNode",
          "content": "tag"
        }
      ]
    }
  ]
}</ExpectedJsonString>
  </MdTestData>
