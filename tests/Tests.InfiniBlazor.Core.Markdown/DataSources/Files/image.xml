    <ExpectedHtmlString>&lt;p class="my-4 leading-relaxed"&gt;&lt;img src="https://localhost:7210/icon.png" class="inline-block rounded-lg shadow-lg h-full w-auto object-contain" alt="" style="width:100px;height:100px;" /&gt;&lt;/p&gt;&lt;p class="my-4 leading-relaxed"&gt;&lt;img src="https://localhost:7210/icon.png" class="inline-block rounded-lg shadow-lg h-full w-auto object-contain" alt="" title="something" /&gt;&lt;/p&gt;&lt;p class="my-4 leading-relaxed"&gt;&lt;img src="https://localhost:7210/icon.png" class="inline-block rounded-lg shadow-lg h-full w-auto object-contain" alt="" style="width:auto;height:1em;vertical-align:text-top;object-fit:contain;transform:translate(0,0.15em);" /&gt;&lt;/p&gt;</ExpectedHtmlString>
