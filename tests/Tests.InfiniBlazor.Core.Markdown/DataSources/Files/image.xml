    <ExpectedHtmlString>&lt;p class="my-4 leading-relaxed"&gt;&lt;img src="https://www.transgenderinfo.be" class="inline-block rounded-lg shadow-lg h-full w-auto object-contain" alt="transgenderinfo" /&gt;&lt;/p&gt;</ExpectedHtmlString>
    <ExpectedMarkdownString>![transgenderinfo](https://www.transgenderinfo.be)</ExpectedMarkdownString>
    <ExpectedMarkdownStringSkipOnWhitespaceMisMatch>True</ExpectedMarkdownStringSkipOnWhitespaceMisMatch>
    <ExpectedJsonString>{
  "type": "MdSyntaxTree",
  "children": [
    {
      "type": "ParagraphMdSyntaxNode",
      "children": [
        {
          "type": "ImageMdSyntaxNode",
          "href": "https://www.transgenderinfo.be",
          "altText": "transgenderinfo"
        }
      ]
    }
  ]
}</ExpectedJsonString>
  </MdTestData>
