  <MdTestData Id="withTitle" FileName="link.xml">
    <MdString>Modifier Title definition
[transgenderinfo](https://www.transgenderinfo.be|title="hrt all day!")

Direct Title definition, with space:
[transgenderinfo](https://www.transgenderinfo.be "hrt all day!")

Direct Title definition, without space: 
[transgenderinfo](https://www.transgenderinfo.be"hrt all day!")</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <TextMdSyntaxNode xml:space="preserve">Modifier Title definition</TextMdSyntaxNode>
      </ParagraphMdSyntaxNode>
      <NewLineMdSyntaxNode />
      <ParagraphMdSyntaxNode>
        <LinkMdSyntaxNode Href="https://www.transgenderinfo.be" Title="">
          <Modifiers>
            <Attributes>
              <Entry Key="title" Start="7" End="21" />
            </Attributes>
            <OriginalInput>|title="hrt all day!"</OriginalInput>
          </Modifiers>
          <TextMdSyntaxNode xml:space="preserve">transgenderinfo</TextMdSyntaxNode>
        </LinkMdSyntaxNode>
      </ParagraphMdSyntaxNode>
      <NewLineMdSyntaxNode />
      <NewLineMdSyntaxNode />
      <ParagraphMdSyntaxNode>
        <TextMdSyntaxNode xml:space="preserve">Direct Title definition, with space:</TextMdSyntaxNode>
      </ParagraphMdSyntaxNode>
      <NewLineMdSyntaxNode />
      <ParagraphMdSyntaxNode>
        <LinkMdSyntaxNode Href="https://www.transgenderinfo.be" Title="hrt all day!">
          <TextMdSyntaxNode xml:space="preserve">transgenderinfo</TextMdSyntaxNode>
        </LinkMdSyntaxNode>
      </ParagraphMdSyntaxNode>
      <NewLineMdSyntaxNode />
      <NewLineMdSyntaxNode />
      <ParagraphMdSyntaxNode>
        <TextMdSyntaxNode xml:space="preserve">Direct Title definition, without space: </TextMdSyntaxNode>
      </ParagraphMdSyntaxNode>
      <NewLineMdSyntaxNode />
      <ParagraphMdSyntaxNode>
        <LinkMdSyntaxNode Href="https://www.transgenderinfo.be" Title="hrt all day!">
          <TextMdSyntaxNode xml:space="preserve">transgenderinfo</TextMdSyntaxNode>
        </LinkMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlStringSimplified>&lt;p&gt;Modifier Title definition&lt;/p&gt;&lt;p&gt;&lt;a href="https://www.transgenderinfo.be"&gt;transgenderinfo&lt;/a&gt;&lt;/p&gt;&lt;p&gt;Direct Title definition, with space:&lt;/p&gt;&lt;p&gt;&lt;a href="https://www.transgenderinfo.be"&gt;transgenderinfo&lt;/a&gt;&lt;/p&gt;&lt;p&gt;Direct Title definition, without space: &lt;/p&gt;&lt;p&gt;&lt;a href="https://www.transgenderinfo.be"&gt;transgenderinfo&lt;/a&gt;&lt;/p&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>Modifier Title definition
[transgenderinfo](https://www.transgenderinfo.be|title="hrt all day!")

Direct Title definition, with space:
[transgenderinfo](https://www.transgenderinfo.be "hrt all day!")

Direct Title definition, without space: 
[transgenderinfo](https://www.transgenderinfo.be "hrt all day!")</ExpectedMarkdownString>
    <ExpectedMarkdownStringSkipOnWhitespaceMisMatch>True</ExpectedMarkdownStringSkipOnWhitespaceMisMatch>
  </MdTestData>
