<?xml version="1.0" encoding="utf-8"?>
<ArrayOfMdTestData xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <MdTestData Id="default" FileName="user.xml">
    <MdString>@default</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <UserMdSyntaxNode xml:space="preserve">default</UserMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlStringSimplified>&lt;p&gt;&lt;span class="md-user"&gt;@default&lt;/span&gt;&lt;/p&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>@default</ExpectedMarkdownString>
    <ExpectedJsonString>{
  "type": "MdSyntaxTree",
  "children": [
    {
      "type": "ParagraphMdSyntaxNode",
      "children": [
        {
          "type": "UserMdSyntaxNode",
          "content": "default"
        }
      ]
    }
  ]
}</ExpectedJsonString>
  </MdTestData>
  <MdTestData Id="empty" FileName="user.xml">
    <MdString>@</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <TextMdSyntaxNode xml:space="preserve">@</TextMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlStringSimplified>&lt;p&gt;@&lt;/p&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>@</ExpectedMarkdownString>
    <ExpectedJsonString>{
  "type": "MdSyntaxTree",
  "children": [
    {
      "type": "ParagraphMdSyntaxNode",
      "children": [
        {
          "type": "TextMdSyntaxNode",
          "content": "@"
        }
      ]
    }
  ]
}</ExpectedJsonString>
  </MdTestData>
  <MdTestData Id="withHyphen" FileName="user.xml">
    <MdString>@username-something

@--username--</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <UserMdSyntaxNode xml:space="preserve">username-something</UserMdSyntaxNode>
      </ParagraphMdSyntaxNode>
      <NewLineMdSyntaxNode />
      <NewLineMdSyntaxNode />
      <ParagraphMdSyntaxNode>
        <UserMdSyntaxNode xml:space="preserve">--username--</UserMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlStringSimplified>&lt;p&gt;&lt;span class="md-user"&gt;@username-something&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span class="md-user"&gt;@--username--&lt;/span&gt;&lt;/p&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>@username-something

@--username--</ExpectedMarkdownString>
    <ExpectedJsonString>{
  "type": "MdSyntaxTree",
  "children": [
    {
      "type": "ParagraphMdSyntaxNode",
      "children": [
        {
          "type": "UserMdSyntaxNode",
          "content": "username-something"
        }
      ]
    },
    {
      "type": "NewLineMdSyntaxNode"
    },
    {
      "type": "NewLineMdSyntaxNode"
    },
    {
      "type": "ParagraphMdSyntaxNode",
      "children": [
        {
          "type": "UserMdSyntaxNode",
          "content": "--username--"
        }
      ]
    }
  ]
}</ExpectedJsonString>
  </MdTestData>
  <MdTestData Id="withUnderscore" FileName="user.xml">
    <MdString>@username_something

@__username__</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <UserMdSyntaxNode xml:space="preserve">username_something</UserMdSyntaxNode>
      </ParagraphMdSyntaxNode>
      <NewLineMdSyntaxNode />
      <NewLineMdSyntaxNode />
      <ParagraphMdSyntaxNode>
        <UserMdSyntaxNode xml:space="preserve">__username__</UserMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlStringSimplified>&lt;p&gt;&lt;span class="md-user"&gt;@username_something&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span class="md-user"&gt;@__username__&lt;/span&gt;&lt;/p&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>@username_something

@__username__</ExpectedMarkdownString>
    <ExpectedJsonString>{
  "type": "MdSyntaxTree",
  "children": [
    {
      "type": "ParagraphMdSyntaxNode",
      "children": [
        {
          "type": "UserMdSyntaxNode",
          "content": "username_something"
        }
      ]
    },
    {
      "type": "NewLineMdSyntaxNode"
    },
    {
      "type": "NewLineMdSyntaxNode"
    },
    {
      "type": "ParagraphMdSyntaxNode",
      "children": [
        {
          "type": "UserMdSyntaxNode",
          "content": "__username__"
        }
      ]
    }
  ]
}</ExpectedJsonString>
  </MdTestData>
</ArrayOfMdTestData>