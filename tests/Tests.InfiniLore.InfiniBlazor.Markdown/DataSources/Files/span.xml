    <ExpectedHtmlStringSimplified>&lt;p&gt;&lt;span style=\"color: red\"&gt;&lt;strong&gt;red bold?&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>&lt;span style=\"color: red\"&gt;**red bold?**&lt;/span&gt;</ExpectedMarkdownString>
  </MdTestData>
