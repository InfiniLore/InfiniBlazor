  <MdTestData Id="inlineEmpty" FileName="span.xml">
    <MdString>*test* &lt;span&gt; something &lt;/span&gt; **bold this**</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <ItalicMdSyntaxNode>
          <ContentMdSyntaxNode xml:space="preserve">test</ContentMdSyntaxNode>
        </ItalicMdSyntaxNode>
        <ContentMdSyntaxNode xml:space="preserve"> </ContentMdSyntaxNode>
        <HtmlSpanMdSyntaxNode TagValue="&lt;span&gt;" Attributes="">
          <ContentMdSyntaxNode xml:space="preserve"> something </ContentMdSyntaxNode>
        </HtmlSpanMdSyntaxNode>
        <ContentMdSyntaxNode xml:space="preserve"> </ContentMdSyntaxNode>
        <BoldMdSyntaxNode>
          <ContentMdSyntaxNode xml:space="preserve">bold this</ContentMdSyntaxNode>
        </BoldMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlStringSimplified>&lt;p&gt;&lt;em&gt;test&lt;/em&gt; &lt;span&gt; something &lt;/span&gt; &lt;strong&gt;bold this&lt;/strong&gt;&lt;/p&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>*test* &lt;span&gt; something &lt;/span&gt; **bold this**</ExpectedMarkdownString>
  </MdTestData>
  <MdTestData Id="inlineWithMarkdown" FileName="span.xml">
