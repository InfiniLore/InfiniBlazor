<?xml version="1.0" encoding="utf-8"?>
<ArrayOfMdTestData xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <MdTestData Id="default" FileName="italic.xml">
    <MdString>*italic*</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <ItalicMdSyntaxNode>
          <ContentMdSyntaxNode xml:space="preserve">italic</ContentMdSyntaxNode>
        </ItalicMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlStringSimplified>&lt;p&gt;&lt;em&gt;italic&lt;/em&gt;&lt;/p&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>*italic*</ExpectedMarkdownString>
  </MdTestData>
  <MdTestData Id="edgeCase_HrTagPossibility" FileName="italic.xml">
    <MdString>some text ****</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <ContentMdSyntaxNode xml:space="preserve">some text </ContentMdSyntaxNode>
        <ItalicMdSyntaxNode>
          <ContentMdSyntaxNode xml:space="preserve">**</ContentMdSyntaxNode>
        </ItalicMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlStringSimplified>&lt;p&gt;some text &lt;em&gt;**&lt;/em&gt;&lt;/p&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>some text ****</ExpectedMarkdownString>
  </MdTestData>
  <MdTestData Id="empty" FileName="italic.xml">
    <MdString>**</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <ContentMdSyntaxNode xml:space="preserve">**</ContentMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlStringSimplified>&lt;p&gt;**&lt;/p&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>**</ExpectedMarkdownString>
  </MdTestData>
  <MdTestData Id="empty_2" FileName="italic.xml">
    <MdString>****</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <ItalicMdSyntaxNode>
          <ContentMdSyntaxNode xml:space="preserve">**</ContentMdSyntaxNode>
        </ItalicMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlStringSimplified>&lt;p&gt;&lt;em&gt;**&lt;/em&gt;&lt;/p&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>****</ExpectedMarkdownString>
  </MdTestData>
  <MdTestData Id="withBold" FileName="italic.xml">
    <MdString>*something **bold** in italic*</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <ItalicMdSyntaxNode>
          <ContentMdSyntaxNode xml:space="preserve">something </ContentMdSyntaxNode>
          <BoldMdSyntaxNode>
            <ContentMdSyntaxNode xml:space="preserve">bold</ContentMdSyntaxNode>
          </BoldMdSyntaxNode>
          <ContentMdSyntaxNode xml:space="preserve"> in italic</ContentMdSyntaxNode>
        </ItalicMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlStringSimplified>&lt;p&gt;&lt;em&gt;something &lt;strong&gt;bold&lt;/strong&gt; in italic&lt;/em&gt;&lt;/p&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>*something **bold** in italic*</ExpectedMarkdownString>
  </MdTestData>
  <MdTestData Id="withBoldAndEscapedAsterix_1" FileName="italic.xml">
    <MdString>*italic *nested \* bold**</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <ItalicMdSyntaxNode>
          <ContentMdSyntaxNode xml:space="preserve">italic </ContentMdSyntaxNode>
        </ItalicMdSyntaxNode>
        <ContentMdSyntaxNode xml:space="preserve">nested </ContentMdSyntaxNode>
        <EscapedCharacterMdSyntaxNode xml:space="preserve">*</EscapedCharacterMdSyntaxNode>
        <ContentMdSyntaxNode xml:space="preserve"> bold**</ContentMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlStringSimplified>&lt;p&gt;&lt;em&gt;italic &lt;/em&gt;nested * bold**&lt;/p&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>*italic *nested \* bold**</ExpectedMarkdownString>
  </MdTestData>
  <MdTestData Id="withEscapedAsterix_1" FileName="italic.xml">
    <MdString>*\*italic*</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <ItalicMdSyntaxNode>
          <EscapedCharacterMdSyntaxNode xml:space="preserve">*</EscapedCharacterMdSyntaxNode>
          <ContentMdSyntaxNode xml:space="preserve">italic</ContentMdSyntaxNode>
        </ItalicMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlStringSimplified>&lt;p&gt;&lt;em&gt;*italic&lt;/em&gt;&lt;/p&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>*\*italic*</ExpectedMarkdownString>
  </MdTestData>
  <MdTestData Id="withEscapedAsterix_2" FileName="italic.xml">
    <MdString>*italic\**</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <ItalicMdSyntaxNode>
          <ContentMdSyntaxNode xml:space="preserve">italic</ContentMdSyntaxNode>
          <EscapedCharacterMdSyntaxNode xml:space="preserve">*</EscapedCharacterMdSyntaxNode>
        </ItalicMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlStringSimplified>&lt;p&gt;&lt;em&gt;italic*&lt;/em&gt;&lt;/p&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>*italic\**</ExpectedMarkdownString>
  </MdTestData>
  <MdTestData Id="withEscapedAsterix_3" FileName="italic.xml">
    <MdString>** \* **</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <BoldMdSyntaxNode>
          <ContentMdSyntaxNode xml:space="preserve"> </ContentMdSyntaxNode>
          <EscapedCharacterMdSyntaxNode xml:space="preserve">*</EscapedCharacterMdSyntaxNode>
          <ContentMdSyntaxNode xml:space="preserve"> </ContentMdSyntaxNode>
        </BoldMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlStringSimplified>&lt;p&gt;&lt;strong&gt; * &lt;/strong&gt;&lt;/p&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>** \* **</ExpectedMarkdownString>
  </MdTestData>
</ArrayOfMdTestData>