<?xml version="1.0" encoding="utf-8"?>
<ArrayOfMdTestData xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <MdTestData Id="default" FileName="link.xml">
    <MdString>[transgenderinfo](https://www.transgenderinfo.be)</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <LinkMdSyntaxNode Href="https://www.transgenderinfo.be">
          <ContentMdSyntaxNode xml:space="preserve">transgenderinfo</ContentMdSyntaxNode>
        </LinkMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlStringSimplified>&lt;p&gt;&lt;a href="https://www.transgenderinfo.be"&gt;transgenderinfo&lt;/a&gt;&lt;/p&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>[transgenderinfo](https://www.transgenderinfo.be)</ExpectedMarkdownString>
    <ExpectedMarkdownStringSkipOnWhitespaceMisMatch>True</ExpectedMarkdownStringSkipOnWhitespaceMisMatch>
  </MdTestData>
  <MdTestData Id="empty" FileName="link.xml">
    <MdString>[]()</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <ContentMdSyntaxNode xml:space="preserve">[]()</ContentMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlStringSimplified>&lt;p&gt;[]()&lt;/p&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>[]()</ExpectedMarkdownString>
    <ExpectedMarkdownStringSkipOnWhitespaceMisMatch>True</ExpectedMarkdownStringSkipOnWhitespaceMisMatch>
  </MdTestData>
  <MdTestData Id="withBold" FileName="link.xml">
    <MdString>[**transgenderinfo**](https://www.transgenderinfo.be)</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <LinkMdSyntaxNode Href="https://www.transgenderinfo.be">
          <BoldMdSyntaxNode>
            <ContentMdSyntaxNode xml:space="preserve">transgenderinfo</ContentMdSyntaxNode>
          </BoldMdSyntaxNode>
        </LinkMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlStringSimplified>&lt;p&gt;&lt;a href="https://www.transgenderinfo.be"&gt;&lt;strong&gt;transgenderinfo&lt;/strong&gt;&lt;/a&gt;&lt;/p&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>[**transgenderinfo**](https://www.transgenderinfo.be)</ExpectedMarkdownString>
    <ExpectedMarkdownStringSkipOnWhitespaceMisMatch>True</ExpectedMarkdownStringSkipOnWhitespaceMisMatch>
  </MdTestData>
  <MdTestData Id="withEscapedBracket" FileName="link.xml">
    <MdString>[\]](https://localhost:7210/icon.png)

[\[](https://localhost:7210/icon.png)</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <LinkMdSyntaxNode Href="https://localhost:7210/icon.png">
          <EscapedCharacterMdSyntaxNode xml:space="preserve">]</EscapedCharacterMdSyntaxNode>
        </LinkMdSyntaxNode>
      </ParagraphMdSyntaxNode>
      <NewLineMdSyntaxNode />
      <NewLineMdSyntaxNode />
      <ParagraphMdSyntaxNode>
        <LinkMdSyntaxNode Href="https://localhost:7210/icon.png">
          <EscapedCharacterMdSyntaxNode xml:space="preserve">[</EscapedCharacterMdSyntaxNode>
        </LinkMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlStringSimplified>&lt;p&gt;&lt;a href="https://localhost:7210/icon.png"&gt;]&lt;/a&gt;&lt;/p&gt;&lt;p&gt;&lt;a href="https://localhost:7210/icon.png"&gt;[&lt;/a&gt;&lt;/p&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>[\]](https://localhost:7210/icon.png)

[\[](https://localhost:7210/icon.png)</ExpectedMarkdownString>
    <ExpectedMarkdownStringSkipOnWhitespaceMisMatch>True</ExpectedMarkdownStringSkipOnWhitespaceMisMatch>
  </MdTestData>
