<?xml version="1.0" encoding="utf-8"?>
<ArrayOfMdTestData xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <MdTestData Id="default" FileName="subscript.xml">
    <MdString>^subscript^</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <SubScriptMdSyntaxNode>
          <ContentMdSyntaxNode xml:space="preserve">subscript</ContentMdSyntaxNode>
        </SubScriptMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlStringSimplified>&lt;p&gt;&lt;sub&gt;subscript&lt;/sub&gt;&lt;/p&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>^subscript^</ExpectedMarkdownString>
  </MdTestData>
  <MdTestData Id="edgeCase_HrTagPossibility" FileName="subscript.xml">
    <MdString>some text ^^^^</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <ContentMdSyntaxNode xml:space="preserve">some text </ContentMdSyntaxNode>
        <SubScriptMdSyntaxNode>
          <ContentMdSyntaxNode xml:space="preserve">^^</ContentMdSyntaxNode>
        </SubScriptMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlStringSimplified>&lt;p&gt;some text &lt;sub&gt;^^&lt;/sub&gt;&lt;/p&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>some text ^^^^</ExpectedMarkdownString>
  </MdTestData>
  <MdTestData Id="edgecaseUnbound" FileName="subscript.xml">
    <MdString>^subscript</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <ContentMdSyntaxNode xml:space="preserve">^subscript</ContentMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlStringSimplified>&lt;p&gt;^subscript&lt;/p&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>^subscript</ExpectedMarkdownString>
  </MdTestData>
  <MdTestData Id="empty" FileName="subscript.xml">
    <MdString>^^</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <ContentMdSyntaxNode xml:space="preserve">^^</ContentMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlStringSimplified>&lt;p&gt;^^&lt;/p&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>^^</ExpectedMarkdownString>
  </MdTestData>
  <MdTestData Id="empty_2" FileName="subscript.xml">
    <MdString>^^^^</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <SubScriptMdSyntaxNode>
          <ContentMdSyntaxNode xml:space="preserve">^^</ContentMdSyntaxNode>
        </SubScriptMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlStringSimplified>&lt;p&gt;&lt;sub&gt;^^&lt;/sub&gt;&lt;/p&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>^^^^</ExpectedMarkdownString>
  </MdTestData>
  <MdTestData Id="withBold" FileName="subscript.xml">
    <MdString>^something **bold** in subscript^</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <SubScriptMdSyntaxNode>
          <ContentMdSyntaxNode xml:space="preserve">something </ContentMdSyntaxNode>
          <BoldMdSyntaxNode>
            <ContentMdSyntaxNode xml:space="preserve">bold</ContentMdSyntaxNode>
          </BoldMdSyntaxNode>
          <ContentMdSyntaxNode xml:space="preserve"> in subscript</ContentMdSyntaxNode>
        </SubScriptMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlStringSimplified>&lt;p&gt;&lt;sub&gt;something &lt;strong&gt;bold&lt;/strong&gt; in subscript&lt;/sub&gt;&lt;/p&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>^something **bold** in subscript^</ExpectedMarkdownString>
  </MdTestData>
  <MdTestData Id="withBoldAndEscapedObelix_1" FileName="subscript.xml">
    <MdString>^subscript **nested \^ bold**^</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <SubScriptMdSyntaxNode>
          <ContentMdSyntaxNode xml:space="preserve">subscript **nested </ContentMdSyntaxNode>
          <EscapedCharacterMdSyntaxNode xml:space="preserve">^</EscapedCharacterMdSyntaxNode>
          <ContentMdSyntaxNode xml:space="preserve"> bold**</ContentMdSyntaxNode>
        </SubScriptMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlStringSimplified>&lt;p&gt;&lt;sub&gt;subscript **nested ^ bold**&lt;/sub&gt;&lt;/p&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>^subscript **nested \^ bold**^</ExpectedMarkdownString>
  </MdTestData>
  <MdTestData Id="withEscapedObelix_1" FileName="subscript.xml">
    <MdString>^\^subscript^</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <SubScriptMdSyntaxNode>
          <EscapedCharacterMdSyntaxNode xml:space="preserve">^</EscapedCharacterMdSyntaxNode>
          <ContentMdSyntaxNode xml:space="preserve">subscript</ContentMdSyntaxNode>
        </SubScriptMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlStringSimplified>&lt;p&gt;&lt;sub&gt;^subscript&lt;/sub&gt;&lt;/p&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>^\^subscript^</ExpectedMarkdownString>
  </MdTestData>
  <MdTestData Id="withEscapedObelix_2" FileName="subscript.xml">
    <MdString>^subscript\^^</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <SubScriptMdSyntaxNode>
          <ContentMdSyntaxNode xml:space="preserve">subscript</ContentMdSyntaxNode>
          <EscapedCharacterMdSyntaxNode xml:space="preserve">^</EscapedCharacterMdSyntaxNode>
        </SubScriptMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlStringSimplified>&lt;p&gt;&lt;sub&gt;subscript^&lt;/sub&gt;&lt;/p&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>^subscript\^^</ExpectedMarkdownString>
  </MdTestData>
  <MdTestData Id="withEscapedObelix_3" FileName="subscript.xml">
    <MdString>^^ \^ ^^</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <SuperScriptMdSyntaxNode>
          <ContentMdSyntaxNode xml:space="preserve"> </ContentMdSyntaxNode>
          <EscapedCharacterMdSyntaxNode xml:space="preserve">^</EscapedCharacterMdSyntaxNode>
          <ContentMdSyntaxNode xml:space="preserve"> </ContentMdSyntaxNode>
        </SuperScriptMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlStringSimplified>&lt;p&gt;&lt;sup&gt; ^ &lt;/sup&gt;&lt;/p&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>^^ \^ ^^</ExpectedMarkdownString>
  </MdTestData>
  <MdTestData Id="withEscapedObelix_4" FileName="subscript.xml">
    <MdString>\^literal little hats\^</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <EscapedCharacterMdSyntaxNode xml:space="preserve">^</EscapedCharacterMdSyntaxNode>
        <ContentMdSyntaxNode xml:space="preserve">literal little hats</ContentMdSyntaxNode>
        <EscapedCharacterMdSyntaxNode xml:space="preserve">^</EscapedCharacterMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlStringSimplified>&lt;p&gt;^literal little hats^&lt;/p&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>\^literal little hats\^</ExpectedMarkdownString>
  </MdTestData>
  <MdTestData Id="withTag" FileName="subscript.xml">
    <MdString>^#tag^</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <SubScriptMdSyntaxNode>
          <TagMdSyntaxNode xml:space="preserve">tag</TagMdSyntaxNode>
        </SubScriptMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlStringSimplified>&lt;p&gt;&lt;sub&gt;&lt;span class="md-tag"&gt;#tag&lt;/span&gt;&lt;/sub&gt;&lt;/p&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>^#tag^</ExpectedMarkdownString>
  </MdTestData>
</ArrayOfMdTestData>