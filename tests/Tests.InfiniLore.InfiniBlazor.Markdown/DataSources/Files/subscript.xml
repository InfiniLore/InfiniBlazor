<?xml version="1.0" encoding="utf-8"?>
<ArrayOfMdTestData xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <MdTestData Id="default" FileName="subscript.xml">
    <MdString>^subscript^</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <SubScriptMdSyntaxNode>
          <ContentMdSyntaxNode xml:space="preserve">subscript</ContentMdSyntaxNode>
        </SubScriptMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlStringSimplified>&lt;p&gt;&lt;sub&gt;subscript&lt;/sub&gt;&lt;/p&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>^subscript^</ExpectedMarkdownString>
  </MdTestData>
  <MdTestData Id="edgeCase_HrTagPossibility" FileName="subscript.xml">
    <MdString>some text ^^^^</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <ContentMdSyntaxNode xml:space="preserve">some text </ContentMdSyntaxNode>
        <SubScriptMdSyntaxNode>
          <ContentMdSyntaxNode xml:space="preserve">^^</ContentMdSyntaxNode>
        </SubScriptMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlStringSimplified>&lt;p&gt;some text &lt;sub&gt;^^&lt;/sub&gt;&lt;/p&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>some text ^^^^</ExpectedMarkdownString>
  </MdTestData>
