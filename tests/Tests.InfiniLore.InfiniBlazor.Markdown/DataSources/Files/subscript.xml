  <MdTestData Id="withBold" FileName="subscript.xml">
    <MdString>^something ^^bold^^ in subscript^</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <SubScriptMdSyntaxNode>
          <ContentMdSyntaxNode xml:space="preserve">something </ContentMdSyntaxNode>
          <SuperScriptMdSyntaxNode>
            <ContentMdSyntaxNode xml:space="preserve">bold</ContentMdSyntaxNode>
          </SuperScriptMdSyntaxNode>
          <ContentMdSyntaxNode xml:space="preserve"> in subscript</ContentMdSyntaxNode>
        </SubScriptMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlStringSimplified>&lt;p&gt;&lt;sub&gt;something &lt;sup&gt;bold&lt;/sup&gt; in subscript&lt;/sub&gt;&lt;/p&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>^something ^^bold^^ in subscript^</ExpectedMarkdownString>
  </MdTestData>
  <MdTestData Id="withBoldAndEscapedAsterix_1" FileName="subscript.xml">
    <MdString>^subscript ^nested \^ bold^^</MdString>
    <MdSyntaxTree>
      <ParagraphMdSyntaxNode>
        <ItalicMdSyntaxNode>
          <ContentMdSyntaxNode xml:space="preserve">subscript </ContentMdSyntaxNode>
        </ItalicMdSyntaxNode>
        <ContentMdSyntaxNode xml:space="preserve">nested </ContentMdSyntaxNode>
        <EscapedCharacterMdSyntaxNode xml:space="preserve">^</EscapedCharacterMdSyntaxNode>
        <ContentMdSyntaxNode xml:space="preserve"> bold^^</ContentMdSyntaxNode>
      </ParagraphMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlStringSimplified>&lt;p&gt;&lt;em&gt;subscript &lt;/em&gt;nested ^ bold^^&lt;/p&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>^subscript ^nested \^ bold^^</ExpectedMarkdownString>
  </MdTestData>
