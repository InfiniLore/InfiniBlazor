@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@using InfiniLore.Lucide
@using Tests.InfiniBlazor.Shared.AutoDocumenting
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@inherits ComponentBase
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@

@* Needed to prevent the buidler from complaining that this isn't a component *@
<InfiniButton></InfiniButton>

@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@
@* ReSharper disable UnusedParameter.Local *@
@code {
    #region Default
    public static AutoDocumentTestData GetDefault() {
        return new AutoDocumentTestData(
            "<InfiniButton>Button</InfiniButton>",
            GetRenderFragment()
        );
        RenderFragment GetRenderFragment() => __builder => {
            <InfiniButton>Button</InfiniButton>
        };
    }
    #endregion

    #region Empty
    public static AutoDocumentTestData GetEmpty() {
        return new AutoDocumentTestData(
            "<InfiniButton></InfiniButton>",
            GetRenderFragment()
        );
        RenderFragment GetRenderFragment() => __builder => {
            <InfiniButton></InfiniButton>
        };
    }
    #endregion

    #region WithIsDisabled
    public static AutoDocumentTestData GetWithIsDisabled() {
        return new AutoDocumentTestData(
            "<InfiniButton IsDisabled=\"true\">Button</InfiniButton>",
            GetRenderFragment()
        );
        RenderFragment GetRenderFragment() => __builder => {
            <InfiniButton IsDisabled="true">Button</InfiniButton>
        };
    }
    #endregion

    #region WithIconNameLucide
    public static AutoDocumentTestData GetWithIconNameLucide() {
        return new AutoDocumentTestData(
            "<InfiniButton IconName=\"@LucideNames.Signature\">Sign</InfiniButton>",
            GetRenderFragment()
        );
        RenderFragment GetRenderFragment() => __builder => {
            <InfiniButton IconName="@LucideNames.Signature">Sign</InfiniButton>
        };
    }
    #endregion

    #region GetWithOnClick
    public static AutoDocumentTestData GetWithOnClick() {
        return new AutoDocumentTestData(
            "<InfiniButton OnClick=\"@(() => Console.WriteLine(\"DoSomething\"))\">Do Something</InfiniButton>",
            new InfiniButtonTest().GetRenderFragment_GetWithOnClick()
        );
    }
    private RenderFragment GetRenderFragment_GetWithOnClick() => __builder => {
        <InfiniButton OnClick="@(() => DoSomething())">Do Something</InfiniButton>
    };
    public void DoSomething() {}
    #endregion
}