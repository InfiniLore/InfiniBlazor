@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@using Tests.InfiniBlazor.Shared.AutoDocumenting
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@inherits ComponentBase
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@

@* Needed to prevent the buidler from complaining that this isn't a component *@
<div></div>

@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@
@* ReSharper disable UnusedParameter.Local *@
@code {
    #region Default
    public static AutoDocumentTestData GetDefault() {
        return new AutoDocumentTestData(
            """
            <p>Something</p>
            <p>Else</p>
            """,
            GetRenderFragment()
        );
        RenderFragment GetRenderFragment() => __builder => {
            <p>Something</p>
            <p>Else</p>
        };
    }
    #endregion

    #region Empty
    public static AutoDocumentTestData GetEmpty() {
        return new AutoDocumentTestData(
            "<p></p>",
            GetRenderFragment()
        );
        RenderFragment GetRenderFragment() => __builder => {
            <p></p>
        };
    }
    #endregion
}