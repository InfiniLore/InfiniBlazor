<?xml version="1.0" encoding="utf-8"?>
<ArrayOfMdTestData xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <MdTestData Id="customIcon" FileName="callout.xml">
    <DeveloperNote>The icon name "undefined" is not a valid icon name for the IconProvider, though this should not matter for the paring.</DeveloperNote>
    <MdString>&gt;[!note|icon=signature] Title
&gt; Body

&gt;[!note|icon=undefined] Title
&gt; Body</MdString>
    <MdSyntaxTree>
      <CalloutMdSyntaxNode CalloutType="note" CollapsedState="None" LeadingSpaces="0">
        <Modifiers>
          <Attributes>
            <Entry Key="icon" Start="6" End="15" />
          </Attributes>
          <OriginalInput>|icon=signature</OriginalInput>
        </Modifiers>
        <CalloutTitleMdSyntaxNode>
          <ContentMdSyntaxNode xml:space="preserve">Title</ContentMdSyntaxNode>
        </CalloutTitleMdSyntaxNode>
        <CalloutBodyMdSyntaxNode>
          <ParagraphMdSyntaxNode>
            <ContentMdSyntaxNode xml:space="preserve">Body</ContentMdSyntaxNode>
          </ParagraphMdSyntaxNode>
        </CalloutBodyMdSyntaxNode>
      </CalloutMdSyntaxNode>
      <NewLineMdSyntaxNode />
      <NewLineMdSyntaxNode />
      <CalloutMdSyntaxNode CalloutType="note" CollapsedState="None" LeadingSpaces="0">
        <Modifiers>
          <Attributes>
            <Entry Key="icon" Start="6" End="15" />
          </Attributes>
          <OriginalInput>|icon=undefined</OriginalInput>
        </Modifiers>
        <CalloutTitleMdSyntaxNode>
          <ContentMdSyntaxNode xml:space="preserve">Title</ContentMdSyntaxNode>
        </CalloutTitleMdSyntaxNode>
        <CalloutBodyMdSyntaxNode>
          <ParagraphMdSyntaxNode>
            <ContentMdSyntaxNode xml:space="preserve">Body</ContentMdSyntaxNode>
          </ParagraphMdSyntaxNode>
        </CalloutBodyMdSyntaxNode>
      </CalloutMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlStringSimplified>&lt;div class="md-callout md-callout-note icon-signature"&gt;&lt;div class="md-callout-title"&gt;Title&lt;/div&gt;&lt;div class="md-callout-body"&gt;&lt;p&gt;Body&lt;/p&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class="md-callout md-callout-note icon-undefined"&gt;&lt;div class="md-callout-title"&gt;Title&lt;/div&gt;&lt;div class="md-callout-body"&gt;&lt;p&gt;Body&lt;/p&gt;&lt;/div&gt;&lt;/div&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>&gt;[!note|icon=signature] Title
&gt; Body

&gt;[!note|icon=undefined] Title
&gt; Body</ExpectedMarkdownString>
    <ExpectedMarkdownStringSkipOnWhitespaceMisMatch>True</ExpectedMarkdownStringSkipOnWhitespaceMisMatch>
  </MdTestData>
