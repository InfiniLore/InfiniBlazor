  <MdTestData Id="withNestedCalloutAndCustomIcons" FileName="callout.xml">
    <MdString>&gt;[!note|icon=signature] **Do Something**
&gt;&gt;[!note|icon=signature] **Do Something**
&gt;&gt; Body Content</MdString>
    <MdSyntaxTree>
      <CalloutMdSyntaxNode CalloutType="note" CollapsedState="None" LeadingSpaces="0">
        <Modifiers>
          <Attributes>
            <Entry Key="icon" Start="6" End="15" />
          </Attributes>
          <OriginalInput>|icon=signature</OriginalInput>
        </Modifiers>
        <CalloutTitleMdSyntaxNode>
          <BoldMdSyntaxNode>
            <ContentMdSyntaxNode xml:space="preserve">Do Something</ContentMdSyntaxNode>
          </BoldMdSyntaxNode>
        </CalloutTitleMdSyntaxNode>
        <CalloutBodyMdSyntaxNode>
          <CalloutMdSyntaxNode CalloutType="note" CollapsedState="None" LeadingSpaces="0">
            <Modifiers>
              <Attributes>
                <Entry Key="icon" Start="6" End="15" />
              </Attributes>
              <OriginalInput>|icon=signature</OriginalInput>
            </Modifiers>
            <CalloutTitleMdSyntaxNode>
              <BoldMdSyntaxNode>
                <ContentMdSyntaxNode xml:space="preserve">Do Something</ContentMdSyntaxNode>
              </BoldMdSyntaxNode>
            </CalloutTitleMdSyntaxNode>
            <CalloutBodyMdSyntaxNode>
              <ParagraphMdSyntaxNode>
                <ContentMdSyntaxNode xml:space="preserve">Body Content</ContentMdSyntaxNode>
              </ParagraphMdSyntaxNode>
            </CalloutBodyMdSyntaxNode>
          </CalloutMdSyntaxNode>
        </CalloutBodyMdSyntaxNode>
      </CalloutMdSyntaxNode>
    </MdSyntaxTree>
    <ExpectedHtmlStringSimplified>&lt;div class="md-callout md-callout-note icon-signature"&gt;&lt;div class="md-callout-title"&gt;&lt;strong&gt;Do Something&lt;/strong&gt;&lt;/div&gt;&lt;div class="md-callout-body"&gt;&lt;div class="md-callout md-callout-note icon-signature"&gt;&lt;div class="md-callout-title"&gt;&lt;strong&gt;Do Something&lt;/strong&gt;&lt;/div&gt;&lt;div class="md-callout-body"&gt;&lt;p&gt;Body Content&lt;/p&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;</ExpectedHtmlStringSimplified>
    <ExpectedMarkdownString>&gt;[!note|icon=signature] **Do Something**
&gt; &gt;[!note|icon=signature] **Do Something**
&gt; &gt; Body Content</ExpectedMarkdownString>
    <ExpectedMarkdownStringSkipOnWhitespaceMisMatch>True</ExpectedMarkdownStringSkipOnWhitespaceMisMatch>
  </MdTestData>
