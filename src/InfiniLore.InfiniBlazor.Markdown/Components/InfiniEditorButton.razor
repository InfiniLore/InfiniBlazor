@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@* ReSharper disable once CheckNamespace *@
@namespace InfiniLore.InfiniBlazor.Components
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@inherits ComponentBase
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<InfiniButton OnClick="@(async () => await Editor.OnModifierClickAsync(ModifierName))"
              Variant="ButtonVariant.Transparent"
              IconName="@IconName"/>
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@
@code {
    [CascadingParameter] public InfiniMarkdownEditor Editor { get; set; } = null!;
    [Parameter, EditorRequired] public string ModifierName { get; set; } = null!;
    [Parameter, EditorRequired] public string IconName { get; set; } = null!;
}