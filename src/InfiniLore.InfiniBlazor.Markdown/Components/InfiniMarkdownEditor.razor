@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@namespace InfiniLore.InfiniBlazor.Components
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@inherits ComponentBase
@implements IAsyncDisposable
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<CascadingValue Value="@this" IsFixed="true">
    <div class="@Class flex flex-col flex-1 min-h-0">
        <div class="flex flex-none w-full">
            <InfiniMarkdownEditorToolbar Class="@(ShowPreview ? "w-1/2" : "w-full")">
                <ToolbarButtons>
                    <InfiniEditorButton ModifierName="bold" IconName="bold"/>
                    <InfiniEditorButton ModifierName="italic" IconName="italic"/>
                    <InfiniEditorButton ModifierName="underline" IconName="underline"/>
                    <InfiniEditorButton ModifierName="strike" IconName="strikethrough"/>
                    <InfiniEditorButton ModifierName="superscript" IconName="superscript"/>
                    <InfiniEditorButton ModifierName="subscript" IconName="subscript"/>

                    <div class="grow"></div>

                    <InfiniButton OnClick="DebugLoremAsync">Lorem</InfiniButton>
                    <InfiniButton OnClick="DebugTableAsync">Table</InfiniButton>
                </ToolbarButtons>
            </InfiniMarkdownEditorToolbar>

            @if (ShowPreview) {
                <!-- Preview header (Right side) - Empty but maintains layout -->
                <div class="w-1/2"></div>
            }
        </div>

        <div class="flex flex-1 min-h-0 border border-(--border-color) rounded-tr-lg rounded-b-lg">
            <InfiniMarkdownInput Class="@(ShowPreview ? "w-1/2" : "w-full")"/>
            @if (ShowPreview) { <InfiniMarkdownPreview Class="w-1/2"/> }
        </div>
    </div>
</CascadingValue>
