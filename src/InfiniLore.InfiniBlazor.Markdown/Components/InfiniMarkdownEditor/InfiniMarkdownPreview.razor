@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@namespace InfiniLore.InfiniBlazor.Components
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@inherits Infinilore.InfiniBlazor.Components.InfiniComponentBase
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<div class="@Class flex min-h-0">
    <div class="flex-1 overflow-y-auto infini-scrollbar">
        @if (!VisualDebugger.IsEnabled()) {
            <div class="px-4 max-w-none">
                @ParentEditor.MarkdownOutput
            </div>
        }
        else {
            <InfiniCodeBlock Class="h-full text-(--debug-red)"
                             Content="@PrettifyHtml(MarkdownStringOutput)"/>
        }
    </div>
</div>

