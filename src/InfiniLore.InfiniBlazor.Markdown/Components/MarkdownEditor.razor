@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@using InfiniLore.Lucide
@using InfiniLore.InfiniBlazor.Markdown

@namespace InfiniLore.InfiniBlazor.Components;
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@inherits ComponentBase
@implements IAsyncDisposable
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<div class="flex flex-col h-screen">
    <!-- Header with toolbar -->
    <div class="flex ">
        <!-- Editor toolbar (Left side) -->
        <div class="w-1/2 flex justify-between items-center bg-white px-4 py-2 border-b border-r border-gray-200">
            <!-- Left-Aligned Buttons -->
            <div class="flex space-x-1">
                @foreach (ITextModifier textModifier in textEditor.Modifiers) {
                    <button class="p-1 text-gray-700 hover:bg-gray-100 rounded-lg transition-colors duration-150 ease-in-out focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2"
                            title="@textModifier.ModifierName"
                            @onclick="() => OnModifierClickAsync(textModifier.ModifierName)">
                        <LucideIcon Name="@textModifier.IconName" class="w-5 h-5"/>
                    </button>
                }
            </div>

            <!-- Right-Aligned Buttons -->
            <div class="flex space-x-2">
                <button class="px-3 py-1.5 bg-gray-50 text-gray-700 rounded-md border border-gray-200 hover:bg-gray-100 transition-colors duration-150 ease-in-out focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium"
                        @onclick="DebugLoremAsync">
                    Lorem
                </button>
                <button class="px-3 py-1.5 bg-gray-50 text-gray-700 rounded-md border border-gray-200 hover:bg-gray-100 transition-colors duration-150 ease-in-out focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium"
                        @onclick="DebugTableAsync">
                    Table
                </button>
            </div>
        </div>
        <!-- Preview header (Right side) - Empty but maintains layout -->
        <div class="w-1/2 "></div>
    </div>

    <!-- Main content area -->
    <div class="flex flex-grow">
        <!-- Editor content -->
        <div class="w-1/2 border-r border-gray-300">
            <textarea
                class="w-full h-full p-4 border-none focus:outline-none resize-none"
                @ref="_textareaRef"
                @bind-value="Text" @bind-value:event="oninput"
                @onkeydown="OnKeyDownAsync"
            >
            </textarea>
        </div>

        <!-- Preview content -->
        <div class="w-1/2 p-4 overflow-auto">
            <div class="prose max-w-full">
                @MarkdownOutput
            </div>
        </div>
    </div>
</div>
