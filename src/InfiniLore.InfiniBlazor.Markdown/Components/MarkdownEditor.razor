@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@using InfiniLore.InfiniBlazor.TextEditor
@using InfiniLore.Lucide
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@inherits ComponentBase
@implements IAsyncDisposable
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<div class="flex h-screen">
    <!-- Editor (Left side, 50%) -->
    <div class="w-1/2 flex flex-col border-r border-gray-300">
        <!-- Toolbar inside the top of the editor -->
        <div class="flex justify-between bg-gray-100 px-2 py-1 border-b border-gray-300">
            <!-- Left-Aligned Buttons -->
            <div class="flex space-x-2">
                @foreach (ITextModifier textModifier in textEditor.Modifiers) {
                    <button class="px-1.5 py-1 bg-blue-500 text-white rounded" @onclick="() => OnModifierClickAsync(textModifier.ModifierName)">
                        <LucideIcon Name="@textModifier.IconName"/>
                    </button>
                }
            </div>

            <!-- Right-Aligned Buttons -->
            <div class="flex space-x-2">
                <button class="px-2 py-1 bg-red-500 text-white rounded" @onclick="DebugLoremAsync">
                    Lorem
                </button>
                <button class="px-2 py-1 bg-red-500 text-white rounded" @onclick="DebugTableAsync">
                    Table
                </button>
            </div>
        </div>


        <!-- Textarea -->
        <textarea
            class="flex-grow p-4 border-none focus:outline-none resize-none"
            @ref="_textareaRef"
            @bind-value="Text" @bind-value:event="oninput" 
            @onkeydown="OnKeyDownAsync"
        >
        </textarea>
    </div>

    <!-- Preview (Right side, 50%) -->
    <div class="w-1/2 p-4 overflow-auto">
        <div class="prose max-w-full">
            @MarkdownOutput
        </div>
    </div>
</div>