@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@using InfiniLore.Blazor.Services
@using InfiniLore.Lucide
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@inherits ComponentBase
@inject IMarkdownParser MarkdownParser
@inject IJsRuntimeHelper JsRuntimeHelper
@inject ITextEditor TextEditor
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<div class="flex h-screen">
    <!-- Editor (Left side, 50%) -->
    <div class="w-1/2 flex flex-col border-r border-gray-300">
        <!-- Toolbar inside the top of the editor -->
        <div class="flex space-x-2 bg-gray-100 px-2 py-1 border-b border-gray-300">
            <button class="px-2 py-1 bg-blue-500 text-white rounded" @onclick="() => ApplyFormattingToSelection(Bold)">
                <LiBold/>
            </button>
            <button class="px-2 py-1 bg-blue-500 text-white rounded" @onclick="() => ApplyFormattingToSelection(Italic)">
                <LiItalic/>
            </button>
        </div>

        <!-- Textarea -->
        <textarea
            class="flex-grow p-4 border-none focus:outline-none resize-none"
            @ref="_textareaRef"
            @bind="LastKnownContent"
            @oninput="TextAreaOnChange"
            @onselect="OnTextSelectedAsync"
            @onkeydown="OnKeyDownAsync"
        >
        </textarea>
    </div>

    <!-- Preview (Right side, 50%) -->
    <div class="w-1/2 p-4 overflow-auto">
        <div class="prose max-w-full">
            @MarkdownOutput
        </div>
    </div>
</div>

<script>
    document.addEventListener('keydown', function (e) {
        if (e.ctrlKey) {
            e.preventDefault();
        }
    });
</script>

@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@
@code {
    private MarkupString MarkdownOutput { get; set; }
    private string LastKnownContent { get; set; } = string.Empty;

    private ElementReference _textareaRef;
    private int _selectionStart;
    private int _selectionEnd;

    private const string Bold = "**";
    private const string Italic = "*";
    // -----------------------------------------------------------------------------------------------------------------
    // Methods
    // -----------------------------------------------------------------------------------------------------------------
    private void UpdateMarkdown() {
        MarkdownOutput = new MarkupString(MarkdownParser.Parse(LastKnownContent));
    }
    private void TextAreaOnChange(ChangeEventArgs args) {
        if (args.Value is not string content) return;

        LastKnownContent = content;
        UpdateMarkdown();
    }

    private async Task OnTextSelectedAsync() {
        _selectionStart = await JsRuntimeHelper.GetSelectionStartAsync(_textareaRef);
        _selectionEnd = await JsRuntimeHelper.GetSelectionEndAsync(_textareaRef);
    }


    private void ApplyFormattingToSelection(string wrapper) {
        if (_selectionStart == _selectionEnd) return;

        LastKnownContent = LastKnownContent
            .Insert(_selectionEnd, wrapper)
            .Insert(_selectionStart, wrapper);

        UpdateMarkdown();

        _selectionStart -= wrapper.Length;
        _selectionEnd += wrapper.Length;
    }

    private string _lastPressedKey = string.Empty;
    private async Task OnKeyDownAsync(KeyboardEventArgs obj) {
        if (_lastPressedKey != string.Empty) {
            switch (obj) {
                case { CtrlKey: true, Key: "1" }: {
                    // at the beginning of the current line where the cursor is, place a #
                    break;
                }
            }

            _lastPressedKey = string.Empty;
            return;
        }

        switch (obj) {
            case { CtrlKey: true, Key: "a" or "A" }: {
                await JsRuntimeHelper.SetSelectionRangeAsync(_textareaRef, 0, int.MaxValue);
                break;
            }

            case { CtrlKey: true, Key: "b" }: {
                ApplyFormattingToSelection(Bold);
                break;
            }
                
            case { CtrlKey: true, Key: "i" }: {
                ApplyFormattingToSelection(Bold);
                break;
            }

            case { CtrlKey: true, Key: "h" }: {
                _lastPressedKey = "h";
                break;
            }

        }
    }
}