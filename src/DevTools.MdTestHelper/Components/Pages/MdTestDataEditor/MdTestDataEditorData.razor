@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@using InfiniLore.InfiniBlazor.Markdown
@using InfiniLore.InfiniBlazor.Toasting
@using Tests.Shared.Infinilore.InfiniBlazor

@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@inject IMarkdownParser MarkdownParser
@inject IToastingProvider ToastingProvider
@inject MdTestDataProvider MdTestDataProvider

@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<InfiniHeading3>Markdown Test Data Editor</InfiniHeading3>

<div class="flex flex-col size-full ">
    @* Test Data Section *@
    <div class=" flex flex-col gap-2">
        <InfiniTextInput Label="FileName" @bind-Value="FileName"/>
        <InfiniTextInput Label="Test Id" @bind-Value="TestId">
            <InfiniButton OnClick="@OnRenameClickedAsync" >Rename</InfiniButton>
        </InfiniTextInput>
        <InfiniTextAreaInput Label="Added Note" @bind-Value="DeveloperNote" class="h-24"/>

        <div class="w-full flex justify-center gap-2">
            <InfiniButton Variant="ButtonVariant.Default" OnClick="@OnFetchClicked">Fetch</InfiniButton>
            <InfiniButton Variant="ButtonVariant.Default" Color="Color.Green" OnClick="@OnSaveClicked">Save</InfiniButton>
            <InfiniButton Variant="ButtonVariant.Default" Color="Color.Red" OnClick="@OnDeleteClicked">Delete</InfiniButton>
        </div>
    </div>

    <InfiniDivider></InfiniDivider>

    @* Test Editors section *@
    <div class="h-full w-full grid grid-cols-[1fr_auto_1fr] gap-0">
        <div class="h-full w-full flex flex-col gap-1">
            <InfiniHeading4 Class="min-h-6">Markdown Input</InfiniHeading4>

            <InfiniTextAreaInput 
                @bind-Value="@MdString"
                OnInput="@(async () => { if (!FreezeAutoUpdates) await OnGenerateAsync(); })"
                Rows="22"
                Class="font-mono"/>

            <InfiniSpacer/>
            <div class="w-full flex justify-center items-center h-16">
                <InfiniToggleButton Label="Freeze Auto Updates" @bind-Value="FreezeAutoUpdates"/>
                @if (FreezeAutoUpdates) {
                    <InfiniSpacer/>
                    <InfiniButton Variant="ButtonVariant.Default" OnClick="@OnGenerateAsync">Generate Outputs</InfiniButton>
                }
            </div>
        </div>

        <InfiniDivider Orientation="@Orientation.Vertical"/>

        <div class="h-full w-full flex flex-col gap-1 mt-2">
            <InfiniTabContainer>
                <InfiniTabPage TabName="Syntax Tree">
                    <InfiniTextAreaInput
                        @bind-Value="@ExpectedSyntaxTreeString"
                        Rows="22"
                        Class="font-mono w-full"/>
                </InfiniTabPage>

                <InfiniTabPage TabName="Simplified HTML">
                    <InfiniTextAreaInput
                        @bind-Value="@ExpectedHtmlStringSimplified"
                        Rows="22"
                        Class="font-mono w-full"/>
                </InfiniTabPage>

                <InfiniTabPage TabName="Markdown">
                    <InfiniTextAreaInput
                        @bind-Value="@ExpectedMarkdownString"
                        Rows="22"
                        Class="font-mono w-full"/>
                </InfiniTabPage>
            </InfiniTabContainer>
            
            @if (ExpectedMarkdownString.IsNotNullOrWhiteSpace() && !string.Equals(MdString, ExpectedMarkdownString)) {
                <div class="text-red-500 text-center">
                    Markdown does not match expected output.
                    This often means an underlying issue with the markdown parser.
                </div>
            }
        </div>

    </div>
</div>
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@

@code {
    public string FileName { get; set; } = string.Empty;
    public string TestId { get; set; } = string.Empty;
    public string? DeveloperNote { get; set; } = string.Empty;

    private string MdString { get; set; } = string.Empty;

    private MdTestData? TestDataOrigin { get; set; }
    
    private string ExpectedSyntaxTreeString { get; set; } = string.Empty;
    private string? ExpectedHtmlStringSimplified { get; set; } = string.Empty;
    private string? ExpectedMarkdownString { get; set; } = string.Empty;
    
    public bool FreezeAutoUpdates { get; set; }
     

    // -----------------------------------------------------------------------------------------------------------------
    // Methods
    // -----------------------------------------------------------------------------------------------------------------
    private async Task OnGenerateAsync() {
        IMdSyntaxTree tree = MarkdownParser.MarkdownString.SerializeToSyntaxTree(MdString);

        await Task.WhenAll(
            GenerateXmlString(tree),
            GenerateSimpleHtmlString(tree),
            GenerateMarkdownString(tree)
        );

        await GenerateXmlString(tree);


        await InvokeAsync(StateHasChanged);
    }

    private async Task GenerateXmlString(IMdSyntaxTree tree) {
        using MemoryStream memoryStream = new();
        await MarkdownParser.Xml.DeserializeToXmlStreamAsync(memoryStream, tree);

        memoryStream.Position = 0;
        string result = await new StreamReader(memoryStream).ReadToEndAsync();
        ExpectedSyntaxTreeString = result;
    }

    private Task GenerateSimpleHtmlString(IMdSyntaxTree tree) {
        ExpectedHtmlStringSimplified = MarkdownParser.HtmlString.DeserializeToString(tree);
        return Task.CompletedTask;
    }

    private Task GenerateMarkdownString(IMdSyntaxTree tree) {
        ExpectedMarkdownString = MarkdownParser.MarkdownString.DeserializeToString(tree);
        return Task.CompletedTask;
    }

    private async Task OnFetchClicked() {
        List<MdTestData>? dataList = await MdTestDataProvider.TryGetXmlMdTestDataAsync(FileName);
        if (dataList is null) {
            await ToastingProvider.PublishToastAsync(
                new ToastingData("File could not be found", FileName),
                ToastAppearance.Warning
            );
            return;
        }

        if (dataList.FirstOrDefault(data => data.Id == TestId) is not {} testData) {
            var toastData = new ToastingData("Test Id was not valid", TestId);
            await ToastingProvider.PublishToastAsync(toastData, ToastAppearance.Warning);
            return;
        }

        FileName = testData.FileName;
        TestId = testData.Id;
        DeveloperNote = testData.DeveloperNote;

        MdString = testData.MdString;

        if (testData.MdSyntaxTree is {} tree) {
            using MemoryStream memoryStream = new();
            await MarkdownParser.Xml.DeserializeToXmlStreamAsync(memoryStream, tree);

            memoryStream.Position = 0;
            ExpectedSyntaxTreeString = await new StreamReader(memoryStream).ReadToEndAsync();
        }

        ExpectedHtmlStringSimplified = testData.ExpectedHtmlStringSimplified;
        ExpectedMarkdownString = testData.ExpectedMarkdownString;

        TestDataOrigin = testData;

        var successData = new ToastingData("File loaded successfully", FileName);
        await ToastingProvider.PublishToastAsync(successData, ToastAppearance.Success);
    }

    private async Task OnSaveClicked() {
        if (TestId.IsNullOrWhiteSpace()) {
            var toastData = new ToastingData("Test Id was not valid", TestId);
            await ToastingProvider.PublishToastAsync(toastData, ToastAppearance.Warning);
            return;
        }

        var xmlData = new MdTestData {
            FileName = FileName,
            Id = TestId,
            DeveloperNote = DeveloperNote,
            MdString = MdString,
            MdSyntaxTree = MarkdownParser.MarkdownString.SerializeToSyntaxTree(MdString),
            ExpectedHtmlStringSimplified = ExpectedHtmlStringSimplified,
            ExpectedMarkdownString = ExpectedMarkdownString
        };

        if (!await MdTestDataProvider.TryAddOrUpdateAsync(xmlData.FileName, xmlData)) {
            var toastData = new ToastingData("Test could not be saved", TestId);
            await ToastingProvider.PublishToastAsync(toastData, ToastAppearance.Error);
            return;
        }

        await ToastingProvider.PublishToastAsync(
            new ToastingData("Test was saved", TestId),
            ToastAppearance.Success
        );
    }
    
    private async Task OnDeleteClicked() {
        
        if (!await MdTestDataProvider.TryDeleteAsync(FileName, TestId)) {
            var toastData = new ToastingData("Could not delete Test", TestId);
            await ToastingProvider.PublishToastAsync(toastData, ToastAppearance.Warning);
            return;
        }

        FileName = string.Empty;
        TestId = string.Empty;
        DeveloperNote = string.Empty;
        MdString = string.Empty;
        ExpectedHtmlStringSimplified = string.Empty;
        ExpectedMarkdownString = string.Empty;
        ExpectedSyntaxTreeString = string.Empty;
        TestDataOrigin = null;
        
        await ToastingProvider.PublishToastAsync(
            new ToastingData("Test was Deleted", TestId),
            ToastAppearance.Success
        );
    }
    
    private async Task OnRenameClickedAsync() {
        if (TestDataOrigin is null) {
            var toastData = new ToastingData("Could not not rename Test", "Did not come from a valid data source");
            await ToastingProvider.PublishToastAsync(toastData, ToastAppearance.Warning);
            return;
        }

        if (!await MdTestDataProvider.TryRenameTest(FileName, TestDataOrigin.Id, TestId)) {
            var toastData = new ToastingData("Could not not rename Test");
            await ToastingProvider.PublishToastAsync(toastData, ToastAppearance.Warning);
            return;
        }
        
        await ToastingProvider.PublishToastAsync(
            new ToastingData("Test was Renamed", TestId),
            ToastAppearance.Success
        );

        // Re-fetch data
        await OnFetchClicked();
    }
    
}
