@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@using InfiniLore.InfiniBlazor.Markdown.Parsers.Blazor
@using InfiniLore.InfiniBlazor.Markdown.Syntax

@namespace InfiniLore.InfiniBlazor.Markdown.Parsers.Html
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@inject IBlazorMdComponentConverter ComponentConverter
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<CascadingValue Value="@RenderContext">
    @ComponentConverter.RenderRootComponents(SyntaxTree.VisitTopLevelNodes())
</CascadingValue>
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@
@code {
    [Parameter] public IMdSyntaxTree SyntaxTree { get; set; } = MdSyntaxTree.Empty;
    private MdRenderContext RenderContext { get; } = MdRenderContext.NonInteractive;
}