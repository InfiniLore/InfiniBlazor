@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@using InfiniLore.Lucide

@namespace InfiniLore.InfiniBlazor.Components
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@inherits ComponentBase
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<CascadingValue Value="MenuCollapsed">
    <aside class="flex-shrink-0 h-full flex flex-col bgc-(--sidebar-nav-background) border-r border-(--sidebar-nav-border-color)">
        <div class="@(MenuCollapsed ? ClassClosed : ClassOpen) px-2 h-full flex flex-col transition-all duration-300">
            <!-- Top Logo and Hamburger -->
            <div class="@(MenuCollapsed ? "justify-center" : "justify-between") flex items-center h-12 min-h-[3rem] max-h-[3rem] w-full">
                <div class="@(MenuCollapsed ? "opacity-0 w-0 overflow-hidden px-0" : "opacity-100 w-full px-2") flex items-center h-8 min-h-[2rem] max-h-[2rem] transition-all duration-300">
                    @Header
                </div>

                <!-- Hamburger Menu -->
                <button
                    class="text-(--sidebar-hamburger-color) h-8 w-8 min-h-[2rem] min-w-[2rem] flex items-center justify-center rounded hover:bg-(--sidebar-nav-background-hover) hover:text-(--sidebar-nav-text-color-hover) focus:outline-none"
                    @onclick="ToggleMenu">
                    <LiMenu class="w-6 h-6"/>
                </button>
            </div>

            <!-- Navigation -->
            @if (Body is not null) {
                <div class="border-t border-(--sidebar-nav-border-color) flex shrink-0">
                    <nav class="flex flex-col grow space-y-2 mt-4">
                        @Body
                    </nav>
                </div>
            }

            <!-- Profile Section -->
            @if (Footer is not null) {
                <div class="mt-auto border-t border-(--sidebar-nav-border-color) flex pb-1 shrink-0">
                    <div class="flex flex-col grow space-y-2 mt-4 item ">
                        @Footer
                    </div>
                </div>
            }
        </div>
    </aside>
</CascadingValue>

@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@

@code {
    [Parameter] public SideNavMenuSize Size { get; set; } = SideNavMenuSize.Medium;

    [Parameter] public bool MenuCollapsed { get; set; }

    [Parameter] public RenderFragment? Header { get; set; }
    [Parameter] public RenderFragment? Body { get; set; }
    [Parameter] public RenderFragment? Footer { get; set; }

    [Parameter] public EventCallback<bool> MenuCollapsedChanged { get; set; }
    
    private string ClassOpen => Size.ToTailwindWidth();
    private string ClassClosed => "w-14";

    // -----------------------------------------------------------------------------------------------------------------
    // Methods
    // -----------------------------------------------------------------------------------------------------------------
    private async Task ToggleMenu() {
        MenuCollapsed = !MenuCollapsed;// Toggle the collapsed state
        await MenuCollapsedChanged.InvokeAsync(MenuCollapsed); // Notify a parent component about the change
        await InvokeAsync(StateHasChanged);
    }
}
