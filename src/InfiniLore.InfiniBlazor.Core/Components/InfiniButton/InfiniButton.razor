@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@using Infinilore.InfiniBlazor
@using InfiniLore.Lucide

@namespace InfiniLore.InfiniBlazor.Components
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@inherits ComponentBase
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<div class="group/button p-0.5 relative">
    <button @onclick="OnClickAsync"
            type="@Type"
            disabled="@Disabled"
            aria-label="@AriaLabel"
            class="@(Class + DisableClasses) inline-flex items-center justify-center rounded-md transition-all duration-150 transform">
        
        <span class="@TextClasses rounded-md inline-flex items-center gap-2">
            @if (IconName.IsNotNullOrWhiteSpace()) { 
                <LucideIcon Name="@IconName" class="@IconClasses"/>
            }
            @if (ChildContent is not null) { 
                @ChildContent
            }
            @if (IconName.IsNullOrWhiteSpace() && ChildContent is null) {
                <span class="w-8 h-8"></span>
            }
        </span>
    </button>
    @if (!string.IsNullOrEmpty(Tooltip)) {
        <div class="@TooltipAnchorClasses absolute transform px-3 py-1 bg-(--color-base-90) text-(--color-base-10) text-sm rounded-md opacity-0 group-hover/button:opacity-100 transition-opacity duration-200 whitespace-nowrap z-50 pointer-events-none">
            @Tooltip
        </div>
    }
</div>
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@
@code {
    [Parameter] public string? IconName { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    
    /// <summary>
    /// Event handler for the button's click event. Supports the following delegate types:
    /// <list type="bullet">
    ///   <item><description>System.Action - Synchronous action without parameters</description></item>
    ///   <item><description>System.Action&lt;Microsoft.AspNetCore.Components.Web.MouseEventArgs&gt; - Synchronous action with mouse event data</description></item>
    ///   <item><description>System.Func&lt;System.Threading.Tasks.Task&gt; - Async action without parameters</description></item>
    ///   <item><description>System.Func&lt;Microsoft.AspNetCore.Components.Web.MouseEventArgs, System.Threading.Tasks.Task&gt; - Async action with mouse event data</description></item>
    ///   <item><description>Microsoft.AspNetCore.Components.EventCallback&lt;Microsoft.AspNetCore.Components.Web.MouseEventArgs&gt; - Blazor event callback</description></item>
    /// </list>
    /// </summary>
    /// <example>
    /// <code>
    /// &lt;InfiniButton OnClick="() => Console.WriteLine('Clicked')"&gt;Click Me&lt;/InfiniButton&gt;
    /// &lt;InfiniButton OnClick="(MouseEventArgs e) => HandleClick(e.Button)"&gt;Click Me&lt;/InfiniButton&gt;
    /// &lt;InfiniButton OnClick="async () => await DoSomethingAsync()"&gt;Click Me&lt;/InfiniButton&gt;
    /// &lt;InfiniButton OnClick="async (MouseEventArgs e) => await HandleClickAsync(e.Button)"&gt;Click Me&lt;/InfiniButton&gt;
    /// </code>
    /// </example>
    [Parameter] public Delegate? OnClick { get; set; }
    private OnClickUnion OnClickUnion => OnClick ?? default(OnClickUnion);

    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string Type { get; set; } = "button";
    [Parameter] public string? AriaLabel { get; set; }
    [Parameter] public ButtonVariant Variant { get; set; } = ButtonVariant.Default;
    [Parameter] public Size Size { get; set; } = Size.Md;
    [Parameter] public string Class { get; set; } = string.Empty;
    [Parameter] public string? Tooltip { get; set; }
    [Parameter] public Anchor TooltipAnchor { get; set; } = Anchor.Center | Anchor.Bottom;

    private string IconClasses => (Variant, Disabled) switch {
        (ButtonVariant.Primary, false) => "bg-(--color-accent) group-hover/button:bg-(--color-base-70)",
        (ButtonVariant.Transparent, false) => "bg-transparent text-(--color-base-70) group-hover/button:bg-(--color-base-10) group-hover/button:text-(--color-accent)",
        (_, false) => "bg-(--color-base-70) text-(--color-base-00) group-hover/button:text-(--color-accent)",
        (_, true) => "bg-(--color-base-70) text-(--color-base-10)"
    } + " rounded-md";

    private string TooltipAnchorClasses => TooltipAnchor switch {
        Anchor.Center | Anchor.Bottom => "top-full left-1/2 -translate-x-1/2 mt-2",
        Anchor.Left | Anchor.Bottom => "top-full right-1 translate-x-1 mt-2",
        Anchor.Right | Anchor.Bottom => "top-full left-1 -translate-x-1 mt-2",

        Anchor.Center | Anchor.Top => "bottom-full left-1/2 -translate-x-1/2 mb-2",
        Anchor.Left | Anchor.Top => "bottom-full right-1 translate-x-1 mb-2",
        Anchor.Right | Anchor.Top => "bottom-full left-1 -translate-x-1 mb-2",

        Anchor.Left => "top-0 translate-y-1/2 right-full mr-2",
        Anchor.Right => "top-0 translate-y-1/2 left-full ml-2",
        _ => "top-full left-1/2 -translate-x-1/2 mt-2"
    };

    private string TextClasses => (Variant, Disabled) switch {
        (ButtonVariant.Primary, false) => $"bg-(--color-accent) group-hover/button:bg-(--color-base-70) {SizeClasses}",
        (ButtonVariant.Transparent, false) => "bg-transparent",
        (_, false) => $"bg-(--color-base-70) text-(--color-base-00) group-hover/button:text-(--color-accent) hover:ring-2 hover:ring-(--color-accent) {SizeClasses}",
        (_, true) => $"bg-(--color-base-70) text-(--color-base-10) {SizeClasses}"
    };

    private string DisableClasses => Disabled ? "opacity-50 cursor-not-allowed" : "cursor-pointer active:scale-95 hover:scale-105";

    private string SizeClasses => Size switch {
        _ => "px-2 py-1 text-base"
    };
    
    // -----------------------------------------------------------------------------------------------------------------
    // Methods
    // -----------------------------------------------------------------------------------------------------------------
    private async Task OnClickAsync(MouseEventArgs args) {
        if (Disabled) return;
        await OnClickUnion.InvokeAsync(args);
    }
}
