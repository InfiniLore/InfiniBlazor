@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@* ReSharper disable once CheckNamespace *@
@namespace InfiniLore.InfiniBlazor.Components
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@inherits ComponentBase
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<td class="@CssClass">
    @ChildContent
</td>


@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@
@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public string Alignment { get; set; } = "left";

    [Parameter]
    public int TextShade { get; set; } = 90;

    [Parameter]
    public string Class { get; set; } = "";

    private string CssClass => $"p-3 text-sm text-(--color-base-{TextShade}) {(Alignment == "right" ? "text-right" : "")} {Class}";
}
