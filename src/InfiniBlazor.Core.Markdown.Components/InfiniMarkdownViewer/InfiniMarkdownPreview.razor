@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@using InfiniBlazor.Markdown.Parsers.Blazor
@using InfiniBlazor.Markdown.Syntax

@namespace InfiniBlazor.Markdown
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@rendermode InfiniRenderModeProvider.InfiniRenderMode

@inherits InfiniComponentBase

@inject IMarkdownParser MarkdownParser
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<CascadingValue Value="@EditorContext">
    <CascadingValue Value="@RenderContext">
        <InfiniMdEditorPreview/>
    </CascadingValue>
</CascadingValue>

@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@
@code {
    [EditorRequired, Parameter] public string? Content { get; set; } = "# test";

    private MdEditorContext EditorContext { get; set; } = new();
    private MdRenderContext RenderContext { get; } = MdRenderContext.Interactive;
    
    protected override async Task OnParametersSetAsync() {
        await base.OnParametersSetAsync();
        
        IMdSyntaxTree tree = MarkdownParser.FromMarkdown(Content ?? string.Empty).Tree;
        EditorContext.SyntaxTree = tree;
        
        await InvokeAsync(StateHasChanged);
    }
}