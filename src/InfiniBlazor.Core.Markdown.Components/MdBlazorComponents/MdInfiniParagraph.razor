@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@using InfiniBlazor.Markdown.Parsers.Blazor
@using InfiniBlazor.Markdown.Syntax.Nodes

@namespace InfiniBlazor.Markdown.MdBlazorComponents
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@inherits InfiniBlazorMdComponentBase<ParagraphMdSyntaxNode>
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<p class="@GetMarginCss() leading-relaxed">
    @RenderChildContent()
</p>
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@
@code {
    private string GetMarginCss() {
        return SyntaxNode.Parent switch {
            CalloutBodyMdSyntaxNode => "my-2",
            FootnoteDescriptionMdSyntaxNode when SyntaxNode.GetIndexAtParent() is 0 => string.Empty,
            _ => "my-4"
        };
    }
}