@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@using InfiniBlazor.Markdown.Syntax
@using InfiniBlazor.Markdown.Parsers.Blazor
@using InfiniBlazor.Markdown.Syntax.Nodes

@namespace InfiniBlazor.Markdown.MdBlazorComponents
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@inherits InfiniBlazorMdComponentBase<ImageMdSyntaxNode>
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<img
    src="@SyntaxNode.Href"
    class="inline-block rounded-lg shadow-lg h-full w-auto object-contain"
    title="@GetTitle()"
    alt="@SyntaxNode.NormalizedAltText"
    @attributes="GetExtraModifiers()"
>

@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@

@code {
    private const string FitStyling = "width:auto;height:1em;vertical-align:text-top;object-fit:contain;transform:translate(0,0.15em);";

    private static string GetVerticalAlign(string alignValue) => $"vertical-align:{alignValue};";
    private static string GetWithOldValue(object oldValue, string newValue, char sep = ';') => oldValue is string oldString
        ? $"{oldString}{sep}{newValue}"
        : newValue;
    private static string GetSize((int Width, int Height) size) => $"width:{size.Width}px;height:{size.Height}px;";

    // -----------------------------------------------------------------------------------------------------------------
    // Methods
    // -----------------------------------------------------------------------------------------------------------------

    private string? GetTitle() {
        if (SyntaxNode.Title.IsNotNullOrWhiteSpace()) return SyntaxNode.Title;
        if (SyntaxNode.Modifier != null && SyntaxNode.Modifier.TryGetTitle(out string? title)) return title;
        return null;   
    }
    // ReSharper disable UnusedParameter.Local
    private Dictionary<string, object> GetExtraModifiers() {
        var dict = new Dictionary<string, object>();
        if (SyntaxNode.Modifier is not {} modifier) return dict;

        if (modifier.TryGetTitle(out string? title)) {
            dict.AddOrUpdate(
                "title",
                title
            );
        }

        if (modifier.TryGetAlign(out string? align)) {
            dict.AddOrUpdate(
                "style",
                key => GetVerticalAlign(align),
                (key, oldValue) => GetWithOldValue(oldValue, GetVerticalAlign(align))
            );
        }

        if (modifier.TryGetFit(out bool state) && state) {
            dict.AddOrUpdate(
                "style",
                key => FitStyling,
                (key, oldValue) => GetWithOldValue(oldValue, FitStyling)
            );
        }

        if (modifier.TryGetSize(out (int Width, int Height) size)) {
            dict.AddOrUpdate(
                "style",
                key => GetSize(size),
                (key, oldValue) => GetWithOldValue(oldValue, GetSize(size))
            );
        }

        return dict;
    }
    // ReSharper enable UnusedParameter.Local

}
