@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@using InfiniBlazor.Markdown.EditorTools
@namespace InfiniBlazor.Markdown.EditorTools
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@

@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@inherits InfiniComponentBase
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<InfiniMdEditorToolButton 
    OnClick="@OnClickAsync"
    IconName="@IconName"
    Tooltip="@Tooltip"/>

@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@

@code {
    [CascadingParameter] protected MdEditorContext EditorContext { get; set; } = null!;
    [EditorRequired, Parameter] public string IconName { get; set; } = string.Empty;
    [EditorRequired, Parameter] public string Insertable { get; set; } = string.Empty;
    [Parameter] public string Tooltip { get; set; } = string.Empty;
    
    private async Task OnClickAsync(MouseEventArgs obj) {
        await EditorContext.InvokeInsertAsync(Insertable);
    }
}