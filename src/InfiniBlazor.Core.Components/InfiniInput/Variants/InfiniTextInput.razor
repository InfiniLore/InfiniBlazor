@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@namespace InfiniBlazor
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@inherits InfiniInputBase
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<InfiniInputLayout Component="@this">
    <input
        id="@Id"
        type="@Type"
        value="@Value"
        @oninput="@OnInputHandler"
        onchange="@OnChange"
        placeholder="@Placeholder"
        disabled="@IsDisabled"
        attributes="@(AutoFocus ? new Dictionary<string, object> { { "autofocus", "autofocus" } } : null)"
        maxlength="@MaxLength"
        class="@Class @DisabledClasses w-full placeholder-infini-base-40 rounded-md border border-infini-border focus:ring-2 outline-none ring-infini-accent text-sm p-2 shadow-sm transition max-h-10 "/>
    @ChildContent
</InfiniInputLayout>

@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@
@code {
    [Parameter, EditorRequired] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public EventCallback<ChangeEventArgs> OnChange { get; set; }
    [Parameter] public string Placeholder { get; set; } = string.Empty;
    [Parameter] public string Type { get; set; } = "text";
    [Parameter] public bool AutoFocus { get; set; }
    [Parameter] public int? MaxLength { get; set; }

    private string DisabledClasses => IsDisabled
        ? "opacity-50 cursor-not-allowed overload-bg-infini-base-90"
        : "hover:ring-2 overload-bg-infini-base-60";

    // -----------------------------------------------------------------------------------------------------------------
    // Methods
    // -----------------------------------------------------------------------------------------------------------------
    private async Task OnInputHandler(ChangeEventArgs args) {
        if (args.Value is string value) {
            await ValueChanged.InvokeAsync(value);
        }
    }
}
