@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@using InfiniLore.InfiniBlazor.Markdown.Parsers.Blazor
@using InfiniLore.InfiniBlazor.Markdown.Syntax.Nodes

@namespace InfiniLore.InfiniBlazor.Markdown.MdBlazorComponents
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@inherits InfiniBlazorMdComponentBase<CodeInlineMdSyntaxNode>
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<code class="overload-bg-infini-codeblock text-infini-base-20 rounded px-1 font-mono text-sm">
    @{Span<char> span = stackalloc char[SyntaxNode.Content.Length];}
    @if (SyntaxNode.TryGetContentWithoutEscapedBackTicks(span, out int length)) {
        @span[..length].ToString()
    }
    else {
        @SyntaxNode.Content
    }
</code>
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@
@code {
}
