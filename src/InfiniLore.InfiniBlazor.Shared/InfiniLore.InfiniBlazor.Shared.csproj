<Project Sdk="Microsoft.NET.Sdk.Razor">

    <PropertyGroup>
        <TargetFramework>net9.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <RootNamespace>InfiniLore.InfiniBlazor</RootNamespace>
        <DebugType>portable</DebugType>
        <!--        <Optimize>false</Optimize>-->

        <!-- Package metadata -->
        <PackageId>InfiniLore.InfiniBlazor.Shared</PackageId>
        <Version>0.1.0-preview.87</Version>
        <Authors>Anna Sas</Authors>
        <Description>InfiniLore's Component Library</Description>
        <PackageProjectUrl>https://github.com/InfiniLore/InfiniLore.InfiniBlazor</PackageProjectUrl>
        <PackageTags>Blazor;Ui;Design;Components;Library</PackageTags>
        <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
        <PublishRepositoryUrl>true</PublishRepositoryUrl>
        <IncludeSymbols>true</IncludeSymbols>
        <DebugType>embedded</DebugType>
        <PackageLicenseFile>LICENSE</PackageLicenseFile>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <PackageIcon>icon.png</PackageIcon>
    </PropertyGroup>

    <ItemGroup>
        <InternalsVisibleTo Include="InfiniLore.InfiniBlazor.Extensions.AutoDocumentation" />
        <InternalsVisibleTo Include="Tests.InfiniBlazor" />
        <InternalsVisibleTo Include="Tests.InfiniBlazor.Markdown" />
    </ItemGroup>

    <ItemGroup>
        <InternalsVisibleTo Include="InfiniLore.InfiniBlazor" />
        <InternalsVisibleTo Include="InfiniLore.InfiniBlazor.Core.Components" />
        <InternalsVisibleTo Include="InfiniLore.InfiniBlazor.Core.Theming" />
        <InternalsVisibleTo Include="InfiniLore.InfiniBlazor.Core.Markdown" />
        <InternalsVisibleTo Include="InfiniLore.InfiniBlazor.Extensions.AutoDocumentation" />
        <InternalsVisibleTo Include="Tests.InfiniBlazor" />
        <InternalsVisibleTo Include="Tests.InfiniBlazor.Markdown" />
    </ItemGroup>
    
    <ItemGroup>
        <PackageReference Include="CodeOfChaos.Extensions" />
        <PackageReference Include="CodeOfChaos.Extensions.ObjectPool" />
        <PackageReference Include="Microsoft.AspNetCore.Components" />
        <PackageReference Include="Microsoft.AspNetCore.Components.Web" />
        <PackageReference Include="Microsoft.AspNetCore.WebUtilities" />
        <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    </ItemGroup>

</Project>
