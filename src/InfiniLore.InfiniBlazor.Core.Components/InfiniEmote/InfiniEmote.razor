@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@using InfiniLore.Lucide
@using Microsoft.Extensions.Logging
@using System.Collections.Immutable
@using System.Reflection

@namespace InfiniLore.InfiniBlazor.Components
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@inherits InfiniComponentBase
@inject IComponentsConfig ComponentsConfig
@inject IEmoteProvider EmoteProvider
@inject ILogger<InfiniEmote> Logger
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
@{ EmoteProvider.TryGetEntry(Name, out IEmoteEntry? entry);}
@switch (entry) {
    case { ContentType: EmoteContentType.Emoji, Data : {} data }: {
        @data
        break;
    }

    case { ContentType: EmoteContentType.LucideIconName, Data : {} data }: {
        <LucideIcon Name="@data" Class="inline size-[1em]" ></LucideIcon>
        break;
    }

    case { ContentType: EmoteContentType.SvgData, Data : {} data }: {
        @(new MarkupString(data))
        break;
    }

    case { ContentType: EmoteContentType.ResourcePathPng, Data: {} data }: {
        <img 
            src="data:image/png;base64,@GetBase64Image(data)" 
            alt="@Name"
            class="inline-block shadow-lg h-[1em] w-auto align-text-bottom object-contain transform-[translate(0,-0.1em)]"/>
        break;
    }

    // ReSharper disable once RedundantEmptySwitchSection
    default: {
        @OnEmoteNotFound?.Invoke(Name)
        // Emote not found
        break;
    }
}

@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@
@code {
    [EditorRequired, Parameter] public required string Name { get; init; }
    [Parameter] public Func<string, RenderFragment>? OnEmoteNotFound { get; init; }

    private string GetBase64Image(string resourcePath) {
        if (!ComponentsConfig.TryGetEmbeddedResourceAssemblies(out ImmutableArray<Assembly> assemblies)) return string.Empty;

        foreach (Assembly assembly in assemblies) {
            try {
                using Stream? stream = assembly.GetManifestResourceStream(resourcePath);
                if (stream is null) continue; 
                
                using var memoryStream = new MemoryStream();
                stream.CopyTo(memoryStream);
                
                return Convert.ToBase64String(memoryStream.ToArray());
                
            }
            catch (Exception exception) {
                Logger.Error(exception, "Error loading emote resource at {resourcePath}", resourcePath);
            }
        }
        
        Logger.Warning("Emote resource not found at {resourcePath}", resourcePath);
        return string.Empty;
    }
}
