@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@namespace InfiniLore.InfiniBlazor.Components
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@inherits InfiniInputBase
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<InfiniInputLayout Component="@this">
    <textarea
        id="@Id"
        value="@Value"
        @oninput="@OnInputHandler"
        onchange="@OnChange"
        placeholder="@Placeholder"
        disabled="@IsDisabled"
        attributes="@(AutoFocus ? new Dictionary<string, object> { { "autofocus", "autofocus" } } : null)"
        maxlength="@MaxLength"
        rows="@Rows"
        class="@Class @DisabledClasses min-w-24 w-full placeholder-infini-base-40 rounded-md border border-infini-border focus:ring-2 outline-none ring-infini-accent text-sm p-2 shadow-sm transition infini-scrollbar resize-@ResizeMode">
    </textarea>

    @ChildContent
</InfiniInputLayout>

@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@

@code {
    [Parameter, EditorRequired] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public EventCallback<ChangeEventArgs> OnChange { get; set; }
    [Parameter] public EventCallback<ChangeEventArgs> OnInput { get; set; }
    [Parameter] public string Placeholder { get; set; } = string.Empty;
    [Parameter] public bool AutoFocus { get; set; }
    [Parameter] public int? MaxLength { get; set; }
    [Parameter] public int Rows { get; set; } = 1;
    [Parameter] public string ResizeMode { get; set; } = "vertical";// Can be "none", "both", "horizontal", "vertical"

    private string DisabledClasses => IsDisabled
        ? "opacity-50 cursor-not-allowed overload-bg-infini-base-90"
        : "hover:ring-2 overload-bg-infini-base-60";

    // -----------------------------------------------------------------------------------------------------------------
    // Methods
    // -----------------------------------------------------------------------------------------------------------------
    private async Task OnInputHandler(ChangeEventArgs args) {
        if (args.Value is string value) {
            await ValueChanged.InvokeAsync(value);
        }
        await OnInput.InvokeAsync(args);

    }
}
