@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@using InfiniLore.InfiniBlazor.Components.Tags
@using System.Diagnostics.CodeAnalysis

@namespace InfiniLore.InfiniBlazor.Components
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@inherits InfiniComponentBase

@inject ITagLinkProvider TagLinkProvider
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
@if (TryGetValidHref(out string? href)) {
    <a href="@href" class="@BaseCss cursor-pointer">
        @GetContentFragment
    </a>
}
else {
    <span class="@BaseCss">
        @GetContentFragment
    </span>   
}

@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@
@code {
    [EditorRequired, Parameter] public string Content { get; set; } = string.Empty;
    [Parameter] public string? HrefOverload { get; set; }
    
    [CascadingParameter] public ITagLinkContext? TagLinkContext { get; set; }

    private const string BaseCss = "inline-block px-2 py-0.5 rounded-full leading-4 infini-bg-(--color-base-90) text-(--color-accent)";

    // ReSharper disable once UnusedParameter.Local
    private RenderFragment GetContentFragment => __builder => {
        if (TagLinkContext?.IsRenderedMarkdownComponent ?? false) {
            <span>#</span>
        }
        @Content
    };
    
    // -----------------------------------------------------------------------------------------------------------------
    // Methods
    // -----------------------------------------------------------------------------------------------------------------
    private bool TryGetValidHref([NotNullWhen(true)] out string? href) {
        // ReSharper disable once InvertIf
        if (HrefOverload.IsNotNullOrWhiteSpace()) {
            href = HrefOverload;
            return true;
        }
        
        return TagLinkProvider.TryGetLink(Content, out href);
    }
}