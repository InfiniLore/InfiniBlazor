@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@namespace InfiniLore.InfiniBlazor.Components
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@using InfiniLore.InfiniBlazor.Components.Avatars
@inherits InfiniNavLinkBase
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<div @onclick="@OnContainerClick"
     class="@(ConcatClasses(Class, CollapsedState ? "px-1 py-2" : "p-2")) flex flex-nowrap items-center rounded hover:bg-infini-nav-button-hover group transition-all duration-300">
    <span class="@ConcatClasses(Direction.ToFlexRow(), CollapsedState ? "gap-0": "gap-4")  flex items-center w-full transition-all justify-between">
        <span class="@(CollapsedState ? "" : "-ml-1") transition-all duration-300">
            <InfiniAvatar AvatarData="@AvatarData"/>
        </span>

        <!-- User Info -->
        <div
            hidden="@IsHidden"
            class="@(CollapsedState ? "opacity-0 w-0 h-6 overflow-hidden" : "opacity-100 w-auto h-8") flex flex-col justify-center items-end transition-all duration-300">
            <span>
                <a href="@ComputedHref"
                   @onclick:stopPropagation
                   class="font-semibold text-infini-nav-text hover:text-infini-nav-text-hover whitespace-nowrap text-right"
                   style="font-size: clamp(0.45rem, calc(150px / (@UserName.Length * 0.6)), 1rem);"
                   title="@UserName">
                    @UserName
                </a>
            </span>

            <span class="flex items-center justify-between flex-row gap-4 h-[1.25rem] ">
                @Additional
            </span>
        </div>
    </span>
</div>
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@
@code {
    [Parameter] public string UserName { get; set; } = "Unknown Username";
    [Parameter] public string UserImageUrl { get; set; } = string.Empty;
    
    [Parameter] public RenderFragment? Additional { get; set; }
    [Parameter] public Direction Direction { get; set; } = Direction.LeftToRight;

    private AvatarData AvatarData => new(AvatarStatus.Undefined, ComputedHref, UserImageUrl);
    
    // -----------------------------------------------------------------------------------------------------------------
    // Methods
    // -----------------------------------------------------------------------------------------------------------------
    private void OnContainerClick() {
        if (!CollapsedState) return;
        NavigationManager.NavigateTo(ComputedHref);
    }
}

