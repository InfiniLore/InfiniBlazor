@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@namespace InfiniLore.InfiniBlazor.Components
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@

@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<div class="flex h-screen w-screen min-w-screen min-h-screen max-w-screen max-h-screen overflow-hidden">
    @if (Layout.HasFastFlag(NavLayout.BarsPrimary)) {
        <div class="flex flex-col max-h-screen h-screen w-full max-w-full">
            @Top
            <div class="flex flex-row max-w-full w-full max-h-full h-full overflow-hidden">
                @Left
                <div class="relative flex w-full h-full flex-col overflow-auto">
                    @Body
                </div>
                @Right
            </div>
            @Bottom
        </div>
    }
    else if (Layout.HasFastFlag(NavLayout.SidesPrimary)) {
        @Left
        <div class="flex max-h-screen h-screen w-full max-w-full flex-col overflow-hidden">
            @Top
            <div class="relative flex w-full h-full flex-col overflow-auto">
                @Body
            </div>
            @Bottom
        </div>
        @Right
    }
    else if (Layout.HasFastFlag(NavLayout.TopPrimary)) {
        <div class="flex max-h-screen h-screen w-full max-w-full flex-col">
            @Top
            <div class="flex w-full h-full max-w-full max-h-full flex-row overflow-hidden">
                @Left
                <div class="flex w-full h-full max-w-full max-h-full flex-col overflow-hidden">
                    <div class="relative flex w-full h-full flex-col overflow-auto">
                        @Body
                    </div>
                    @Bottom
                </div>
                @Right
            </div>
        </div>
    }
    else if (Layout.HasFastFlag(NavLayout.BottomPrimary)) {
        <div class="flex max-h-screen h-screen w-full max-w-full flex-col">
            <div class="flex w-full h-full max-w-full max-h-full flex-row overflow-hidden">
                @Left
                <div class="flex w-full h-full max-w-full max-h-full flex-col overflow-hidden">
                    @Top
                    <div class="relative flex w-full h-full flex-col overflow-auto">
                        @Body
                    </div>
                </div>
                @Right
            </div>
            @Bottom
        </div>
    }
    else if (Layout.HasFastFlag(NavLayout.LeftPrimary)) {
        @Left
        <div class="flex max-h-screen h-screen w-full max-w-full flex-col overflow-hidden">
            @Top
            <div class="flex w-full h-full max-w-full max-h-full overflow-auto">
                <div class="relative flex w-full h-full flex-col overflow-auto">
                    @Body
                </div>
                @Right
            </div>
            @Bottom
        </div>
    }

    else if (Layout.HasFastFlag(NavLayout.RightPrimary)) {
        <div class="flex max-h-screen h-screen w-full max-w-full flex-col overflow-hidden">
            @Top
            <div class="flex max-w-full w-full max-h-full h-full overflow-hidden">
                @Left
                <div class="relative flex w-full h-full flex-col overflow-auto">
                    @Body
                </div>
            </div>
            @Bottom
        </div>
        @Right
    }
</div>

@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@

@code {
    [Parameter] public RenderFragment? Top { get; set; }
    [Parameter] public RenderFragment? Right { get; set; }
    [Parameter] public RenderFragment? Left { get; set; }
    [Parameter] public RenderFragment? Bottom { get; set; }

    [Parameter] public RenderFragment? Body { get; set; }
    [Parameter] public NavLayout Layout { get; set; } = NavLayout.LeftPrimary;
}