@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@using InfiniLore.InfiniBlazor.Theming
@using Microsoft.Extensions.Logging

@namespace InfiniLore.InfiniBlazor.Components
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@inject IThemeSelector ThemeSelector
@inject ILogger<InfiniThemeManager> Logger

@inherits ComponentBase
@implements IAsyncDisposable
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<style id="infiniThemeManager-selectedTheme-css">@_css</style>
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@
@code {
    private string _css = string.Empty;

    // -----------------------------------------------------------------------------------------------------------------
    // Methods
    // -----------------------------------------------------------------------------------------------------------------
    protected override void OnInitialized() {
        ThemeSelector.ThemeChangedAsync += OnThemeChangedAsync;
        UpdateCss();
    }
    
    private async Task OnThemeChangedAsync() {
        Logger.LogInformation("Theme change detected");
        UpdateCss();
        await InvokeAsync(StateHasChanged);
    }

    public ValueTask DisposeAsync() {
        ThemeSelector.ThemeChangedAsync -= OnThemeChangedAsync;
        return ValueTask.CompletedTask;
    }
    
    private void UpdateCss() {
        if (!ThemeSelector.TryGetCurrentThemeCss(out string? css)) {
            Logger.LogWarning("Could not live update the current css styling");
            return;
        }

        _css = css;
    }
}
