@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@using InfiniLore.InfiniBlazor.Theming
@using Microsoft.Extensions.Logging
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@rendermode InteractiveAuto
@inject IThemeSelector ThemeSelector
@inject ILogger<InfiniBlazorThemeSwitch> Logger
@implements IDisposable
@inherits ComponentBase
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<style>@_css</style>
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@
@code {
    private string _css = string.Empty;

    // -----------------------------------------------------------------------------------------------------------------
    // Methods
    // -----------------------------------------------------------------------------------------------------------------
    protected override void OnInitialized() {
        ThemeSelector.ThemeChanged += OnThemeChanged;
        UpdateCss();
    }
    
    private void OnThemeChanged() {
        UpdateCss();
        InvokeAsync(StateHasChanged);
    }
    
    public void Dispose() {
        ThemeSelector.ThemeChanged -= OnThemeChanged;
    }
    
    private void UpdateCss() {
        if (!ThemeSelector.TryGetCurrentThemeCss(out string? css)) {
            Logger.LogWarning("Could not live update the current css styling");
            return;
        }
        _css = css;
    }
}
