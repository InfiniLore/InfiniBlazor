@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@namespace InfiniLore.InfiniBlazor.Components
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@inherits ComponentBase
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<span class="flex flex-nowrap items-center justify-center">
    <span class="w-6 h-6 text-(--sidebar-nav-text-color) flex-shrink-0 group-hover:text-(--sidebar-nav-text-color-hover)">
        @Icon
    </span>

    @if (Text is not null) {
        <span
            class="@(MenuCollapsed ? "w-0 opacity-0 delay-0" : "delay-300 w-auto ml-2 opacity-100") transition-all duration-300 h-6 overflow-hidden">
            <span class="text-(--sidebar-nav-text-color) truncate inline-block max-w-[150px] group-hover:text-(--sidebar-nav-text-color-hover)">
                @Text
            </span>
        </span>
    }
</span>
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@
@code {
    [CascadingParameter] public bool MenuCollapsed { get; set; }
    [Parameter, EditorRequired] public required RenderFragment? Text { get; set; }
    [Parameter, EditorRequired] public required RenderFragment? Icon { get; set; }

    public static string GetContainerClasses()
        => GetContainerClassesNoHover() + " hover:bg-(--sidebar-nav-button-color-hover)";
    
    public static string GetContainerClassesNoHover() 
        => "flex flex-nowrap items-center bgc-(--sidebar-nav-button-color) rounded group w-full justify-start p-2";
}

