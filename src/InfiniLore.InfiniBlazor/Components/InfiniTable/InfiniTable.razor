@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@namespace InfiniLore.InfiniBlazor.Components
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@inherits InfiniComponentBase
@typeparam TItem
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<div class="@Class shadow-sm rounded-2xl border border-(--border) flex flex-col overflow-hidden">
    <div class="w-full h-full overflow-auto relative infini-scrollbar">
        <table class="w-full h-full table-auto">
            <thead class="sticky top-0 infini-bg-(--table-header) border-(--border) z-10 border-b p-4">
                <tr>
                    @Header
                </tr>
            </thead>
            <tbody>
                @if (!Items.Any()) {
                    <tr>
                        <td colspan="100%" class="text-center py-4">
                            @EmptyMessage
                        </td>
                    </tr>
                } else {
                    int i = 0;
                    foreach (TItem item in Items) {
                        <tr class="group infini-bg-(--table-row) p hover:infini-bg-(--table-row-hover) transition h-4">
                            @if (Content is not null) {
                                @Content(item)
                            } else if (ContentWithIndex is not null) {
                                @ContentWithIndex((item, i++))
                            }
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@
@code {
    [Parameter, EditorRequired] public IEnumerable<TItem> Items { get; set; } = Array.Empty<TItem>();
    [Parameter, EditorRequired] public RenderFragment Header { get; set; } = null!;
    [Parameter] public RenderFragment<TItem>? Content { get; set; }
    [Parameter] public RenderFragment<(TItem, int)>? ContentWithIndex { get; set; }
    [Parameter] public string EmptyMessage { get; set; } = "No entries found";
}
