@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@namespace InfiniLore.InfiniBlazor.Components
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@inherits InfiniComponentBase
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
@if (Title.IsNotNullOrWhiteSpace()) {
    <PageTitle>@Title</PageTitle>
}

@if (VisualDebugger.IsEnabled()) {
    <div class="absolute top-0 right-0 bg-(--color-red) text-(--color-white) transition-opacity duration-500 ease-in-out p-2 rounded-bl-md opacity-75 z-50">
        Render Mode : <strong>@RendererInfo.Name</strong>
    </div>
}

<main class="@Class flex flex-col h-screen flex-1 overflow-y-auto infini-bg-(--page) text-(--page-text) px-4 infini-scrollbar gap-4">
    @ChildContent
</main>
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@
@code {
    [Parameter] public string? Title { get; set; } 
    [CascadingParameter] public IComponentRenderMode? ComponentRenderMode { get; set; }

    protected override void OnInitialized() {
        base.OnInitialized();
        VisualDebugger.InitializeFromUrl();
    }
}