@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@namespace InfiniLore.InfiniBlazor.Components
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@inherits ComponentBase
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<button @onclick="@HandleClickAsync" class="@SideNavMenuItem.ContainerClasses">
    <SideNavMenuItem Text="@Text" Icon="@Icon"/>
</button>

@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@
@code {
    [Parameter] public Action? OnClick { get; set; }
    [Parameter] public Func<Task>? OnClickAsync { get; set; }

    [CascadingParameter] public bool MenuCollapsed { get; set; }
    [Parameter] public RenderFragment? Text { get; set; }
    [Parameter] public RenderFragment? Icon { get; set; }

    // -----------------------------------------------------------------------------------------------------------------
    // Methods
    // -----------------------------------------------------------------------------------------------------------------
    private async Task HandleClickAsync() {
        if (OnClickAsync is not null) {
            await OnClickAsync();
            return;
        }

        OnClick?.Invoke();
    }

}

