@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@using Infinilore.InfiniBlazor
@using InfiniLore.InfiniBlazor.JsRuntime

@namespace InfiniLore.InfiniBlazor.Components
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@inherits InfiniComponentBase
@inject IJsRuntimeHelper JsRuntimeHelper
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<div class="@Class relative flex overflow-hidden min-h-0 text-(--color-base-20)">
    <div class="absolute top-2 right-4 flex justify-end z-10">
        @if (EnableCopy) {
            <InfiniButton
                IconName="copy"
                Variant="ButtonVariant.Dark"
                OnClick="CopyToClipboardAsync"
                Tooltip="Copy to clipboard"
                TooltipAnchor="@Anchor.Left">
                @Language
            </InfiniButton>
        }
    </div>
    <div class="bg-(--color-base-60) text-sm border border-(--border) rounded p-4 overflow-auto w-full min-h-0 infini-scrollbar">
        <div class="relative">
            <pre class="whitespace-pre m-0 font-mono min-h-0"><code>@Content @ChildContent</code></pre>
        </div>
    </div>
</div>


@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@

@code {
    [Parameter] public string? Content { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> ContentChanged { get; set; }
    [Parameter] public string? Language { get; set; }
    [Parameter] public bool EnableCopy { get; set; } = true;
    
    // -----------------------------------------------------------------------------------------------------------------
    // Methods
    // -----------------------------------------------------------------------------------------------------------------
    private async Task CopyToClipboardAsync() {
        if (Content.IsNullOrWhiteSpace()) return;

        await JsRuntimeHelper.CopyToClipboardAsync(Content);
    }
}
