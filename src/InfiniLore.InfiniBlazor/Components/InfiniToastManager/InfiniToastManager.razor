@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@using InfiniLore.InfiniBlazor.Toasting

@* ReSharper disable once CheckNamespace *@
@namespace InfiniLore.InfiniBlazor.Components
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@inject IToastingProvider ToastingProvider
@implements IDisposable
@rendermode InteractiveAuto
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<div class="@ContainerPositionClass fixed z-1000 p-3 space-y-2 max-w-64 w-full max-h-screen overflow-y-auto hide-scrollbar">
    @foreach (IToastEntry toastEntry in ToastingProvider.GetToastEntries()) {
        <DynamicComponent
            @key="toastEntry.Data.Id" 
            Type="@toastEntry.ComponentType"
            Parameters="@ToastMessageBase.GetAsDynamicParameters(toastEntry.Data)"/>
    }
</div>

@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@
@code {
    [Parameter] public ToastPosition Position { get; set; } = ToastPosition.BottomRight;

    // ReSharper disable once PatternIsRedundant
    private string ContainerPositionClass => Position switch {
        ToastPosition.TopRight => "top-4 right-4",
        ToastPosition.TopLeft => "top-4 left-4",
        ToastPosition.BottomLeft => "bottom-4 left-4",
        ToastPosition.BottomRight or _ => "bottom-4 right-4"
    };

    // -----------------------------------------------------------------------------------------------------------------
    // Methods
    // -----------------------------------------------------------------------------------------------------------------
    protected override void OnInitialized() {
        ToastingProvider.OnToastPublished += HandleToastServiceChange;
        ToastingProvider.OnToastUnpublished += HandleToastServiceChange;
    }

    private async Task HandleToastServiceChange() {
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose() {
        ToastingProvider.OnToastPublished -= HandleToastServiceChange;
        ToastingProvider.OnToastUnpublished -= HandleToastServiceChange;
    }
}
