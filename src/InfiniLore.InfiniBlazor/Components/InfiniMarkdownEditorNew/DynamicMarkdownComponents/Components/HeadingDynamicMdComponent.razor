@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@

@namespace InfiniLore.InfiniBlazor.Components.DynamicMarkdownComponents
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@inherits DynamicMdComponentBase<InfiniLore.InfiniBlazor.Markdown.Syntax.Nodes.HeadingMdSyntaxNode>
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<InfiniHeading Size="GetSize()">
    @RenderChildContent()
</InfiniHeading>

@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@
@code {
    public HeadingSize GetSize() => SyntaxNode.Level switch {
        1 => HeadingSize.H1,
        2 => HeadingSize.H2,
        3 => HeadingSize.H3,
        4 => HeadingSize.H4,
        5 => HeadingSize.H5,
        _ => HeadingSize.H6
    };
}
