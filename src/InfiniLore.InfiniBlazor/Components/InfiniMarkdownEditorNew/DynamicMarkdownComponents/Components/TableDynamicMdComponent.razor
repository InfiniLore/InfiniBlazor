@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@using InfiniLore.InfiniBlazor.MarkdownParser.Syntax.Nodes;

@namespace InfiniLore.InfiniBlazor.Components.DynamicMarkdownComponents
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@inherits DynamicMdComponentBase<TableMdSyntaxNode>
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<InfiniTable TItem="TableRowMdSyntaxNode" ItemsBySpan="SyntaxNode.GetRows">
    <Header>
        @foreach (TableCellMdSyntaxNode headerItem in SyntaxNode.GetHeaderCells()) {
            <InfiniTableHeader>@ComponentConverter.RenderChildComponents(headerItem)</InfiniTableHeader>
        }
    </Header>
    <Content Context="rowNode">
        @* The cell itself doesnt hold data, but the content of the cell does *@
        @foreach (TableCellMdSyntaxNode node in rowNode.GetChildrenByType<TableCellMdSyntaxNode>()) {
            <InfiniTableCell>@ComponentConverter.RenderChildComponents(node)</InfiniTableCell>
        }
    </Content>
</InfiniTable>
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@

