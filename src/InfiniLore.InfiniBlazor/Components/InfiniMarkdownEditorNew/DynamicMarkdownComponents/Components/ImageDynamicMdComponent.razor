@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@using InfiniLore.InfiniBlazor.Markdown
@using InfiniLore.InfiniBlazor.Markdown.Syntax

@namespace InfiniLore.InfiniBlazor.Components.DynamicMarkdownComponents
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@inherits DynamicMdComponentBase<InfiniLore.InfiniBlazor.Markdown.Syntax.Nodes.ImageMdSyntaxNode>
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<img 
    src="@SyntaxNode.Href"
    class="inline-block rounded-lg shadow-lg h-full w-auto object-contain" 
    alt="@SyntaxNode.AltText"
    @attributes="GetExtraModifiers()">

@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@
@code {
    private List<KeyValuePair<string, object>> GetExtraModifiers() {
        var list = new List<KeyValuePair<string, object>>();
        if (!SyntaxNode.TryGetModifier(out IMdSyntaxNodeModifier? modifier)) return list;

        if (modifier.TryGetTitle(out string? title)) {
            list.Add(new KeyValuePair<string, object>("title", title));
        }
                    
        if (modifier.TryGetFit(out bool state) && state) {
            list.Add(new KeyValuePair<string, object>("style", "width:auto;height:1em;vertical-align:text-top;object-fit:contain;transform:translate(0,0.15em);"));
        }
                    
        else if (modifier.TryGetSize(out (int Width, int Height) size)) {
            list.Add( new KeyValuePair<string, object>("style", $"width:{size.Width}px;height:{size.Height}px;"));
        }

        return list;
    }

}
