@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@using InfiniLore.InfiniBlazor.Markdown
@using InfiniLore.InfiniBlazor.Markdown.Parsers.Blazor
@using InfiniLore.InfiniBlazor.Markdown.Syntax
@using InfiniLore.InfiniBlazor.TextEditor

@* ReSharper disable once CheckNamespace *@
@namespace InfiniLore.InfiniBlazor.Components
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@inherits InfiniComponentBase
@inject IMarkdownParser Parser
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<CascadingValue Value="@EditorContext">
    <CascadingValue Value="@RenderContext">
        <div class="mdEditor-container flex w-full flex-col h-full">
            <div class="mdEditor-toolbarTop"></div>
            <div class="flex flex-row size-full h-full">
                <InfiniMdEditorInput Class="max-w-1/2 min-w-1/2 w-1/2"/>
                <InfiniMdEditorPreview Class="max-w-1/2 min-w-1/2 w-1/2"/>
            </div>
            <div class="mdEditor-toolbarBottom"></div>
        </div>
    </CascadingValue>
</CascadingValue>


@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@
@code {
    [Parameter] public ITextSource Source { get; set; } = TextSource.Empty;
    private MdEditorContext EditorContext { get; set; } = new();
    private MdRenderContext RenderContext { get; set; } = new();

    // -----------------------------------------------------------------------------------------------------------------
    // Methods
    // -----------------------------------------------------------------------------------------------------------------
    protected override void OnInitialized() {
        base.OnInitialized();
        
        RenderContext.OnSyntaxTreeUpdate += OnSyntaxTreeUpdated;
        EditorContext.OnSourceUpdate += OnSourceUpdated;
    }
    
    protected override void OnParametersSet() {
        base.OnParametersSet();
        EditorContext.SetTextSource(Source);
    }

    public override async ValueTask DisposeAsync() {
        await base.DisposeAsync();
        
        RenderContext.OnSyntaxTreeUpdate -= OnSyntaxTreeUpdated;
        EditorContext.OnSourceUpdate -= OnSourceUpdated;
    }

    private async Task OnSourceUpdated(string newSource) {
        if (EditorContext.SyntaxTree is MdSyntaxTree oldTree) MdSyntaxTree.Pool.Return(oldTree);
        
        IMdSyntaxTree newTree = Parser.MarkdownString.SerializeToSyntaxTree(newSource);
        EditorContext.SyntaxTree = newTree;

        await EditorContext.InvokeSyntaxTreeUpdated().ConfigureAwait(false);
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnSyntaxTreeUpdated() {
        string newContent = Parser.MarkdownString.DeserializeToString(EditorContext.SyntaxTree);
        EditorContext.TextSource.UpdateSource(newContent);
        
        await EditorContext.UpdateSource(newContent).ConfigureAwait(false);
        await InvokeAsync(StateHasChanged);
    }
}