@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@using InfiniLore.InfiniBlazor.JsRuntime
@using InfiniLore.InfiniBlazor.Markdown
@using InfiniLore.InfiniBlazor.Markdown.Parsers.Blazor
@using Microsoft.Extensions.Logging

@* ReSharper disable once CheckNamespace *@
@namespace InfiniLore.InfiniBlazor.Components
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@inherits InfiniComponentBase
@inject IMarkdownParser Parser

@inject IJsInfiniBlazor JsInfiniBlazor
@inject ITextEditor TextEditor
@inject ILogger<InfiniMarkdownEditorNew> Logger
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<CascadingValue Value="@EditorContext">
    <CascadingValue Value="@RenderContext">
        <div class="mdEditor-container flex w-full flex-col h-full">
            <div class="mdEditor-toolbarTop"></div>
            <div class="flex flex-row size-full h-full">
                <InfiniMdEditorInput Class="max-w-1/2 min-w-1/2 w-1/2"/>
                <InfiniMdEditorPreview Class="max-w-1/2 min-w-1/2 w-1/2"/>
            </div>
            <div class="mdEditor-toolbarBottom"></div>
        </div>
    </CascadingValue>
</CascadingValue>

@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@
@code {
    private MdEditorContext EditorContext { get; set; } = new();
    private MdRenderContext RenderContext { get; set; } = new();
    private InfiniEditorKeyCombo LastPressedCombo { get; set; } = InfiniEditorKeyCombo.Empty;
    
    private Dictionary<InfiniEditorKeyCombo, Func<InfiniMarkdownEditorNew,Task>> KeyCombos { get; } = new() {
        [InfiniEditorKeyCombo.Bold] = static editor => editor.OnModifierClickAsync("bold"),
        [InfiniEditorKeyCombo.Italic] = static editor => editor.OnModifierClickAsync("italic"),
        [InfiniEditorKeyCombo.Underline] = static editor => editor.OnModifierClickAsync("underline"),
        [InfiniEditorKeyCombo.SelectAll] = static editor => editor.HandleSelectAllAsync()
    };

    // -----------------------------------------------------------------------------------------------------------------
    // Methods
    // -----------------------------------------------------------------------------------------------------------------
    protected override void OnInitialized() {
        base.OnInitialized();
        
        RenderContext.OnSyntaxNodeChange += OnSyntaxNodeChangedAsync;
        EditorContext.OnSourceUpdate += OnSourceUpdatedAsync;
        EditorContext.OnInputKeyDown += OnInputKeyDownAsync;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender) {
        await base.OnAfterRenderAsync(firstRender);
        if (firstRender) {
            // Only add the "prevent default listener" once.
            await JsInfiniBlazor.KeyDownListener.AddPreventDefaultListenerAsync();
            return;
        }

        // place the caret in a newly requested location
        if (TextEditor.TryGetCaretUpdate(out int index))
            await JsInfiniBlazor.TextSelection.SetIndexAsync(EditorContext.InputElementRef, index);
    }
    
    public override async ValueTask DisposeAsync() {
        await base.DisposeAsync();
        
        RenderContext.OnSyntaxNodeChange -= OnSyntaxNodeChangedAsync;
        EditorContext.OnSourceUpdate -= OnSourceUpdatedAsync;
        EditorContext.OnInputKeyDown -= OnInputKeyDownAsync;
        await JsInfiniBlazor.KeyDownListener.RemovePreventDefaultListenerAsync();
    }

    private async Task OnSourceUpdatedAsync(string newSource) {
        EditorContext.TextSource.UpdateSource(newSource);

        EditorContext.SyntaxTree.ReturnToPool();
        EditorContext.SyntaxTree = Parser.MarkdownString.SerializeToSyntaxTree(EditorContext.TextSource.Text);
        await EditorContext.InvokeSyntaxTreeUpdatedAsync();
        await InvokeAsync(StateHasChanged);
    }

    private Task OnSyntaxNodeChangedAsync(IMdSyntaxNode _) => OnSyntaxTreeChanged();

    private async Task OnSyntaxTreeChanged() {
        string newContent = Parser.MarkdownString.DeserializeToString(EditorContext.SyntaxTree);
        EditorContext.TextSource.UpdateSource(newContent);
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnInputKeyDownAsync(KeyboardEventArgs args) {
        InfiniEditorKeyCombo combo = InfiniEditorKeyCombo.From(args);
        if (KeyCombos.TryGetValue(combo, out Func<InfiniMarkdownEditorNew, Task>? task)) await task(this);
        
        LastPressedCombo = combo;
        await InvokeAsync(StateHasChanged);
    }
    
    public async Task OnModifierClickAsync(string modifierName) {
        if (EditorContext.IsLocked) return;

        Range range = await JsInfiniBlazor.TextSelection.GetRangeAsync(EditorContext.InputElementRef);
        TextEditor.Modify(EditorContext.TextSource, modifierName, range);
        await EditorContext.InvokeSourceUpdatedAsync(EditorContext.TextSource.Text);
        await InvokeAsync(StateHasChanged);
    }

    public async Task OnInsertClickAsync(string content) {
        if (EditorContext.IsLocked) return;

        Range range = await JsInfiniBlazor.TextSelection.GetRangeAsync(EditorContext.InputElementRef);
        TextEditor.Insert(EditorContext.TextSource, content, range);
        await EditorContext.InvokeSourceUpdatedAsync(EditorContext.TextSource.Text);
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleSelectAllAsync() {
        if (EditorContext.IsLocked) return;
        if (EditorContext.TextSource.IsEmpty) return;

        // when ctrl+a has been pressed twice, select the full text
        if (LastPressedCombo == InfiniEditorKeyCombo.SelectAll) {
            Range fullRange = new(0, EditorContext.TextSource.Length);
            await JsInfiniBlazor.TextSelection.SetRangeAsync(EditorContext.InputElementRef, fullRange);
            return;
        }
        
        // when ctrl+a has been pressed only once, select the current line
        int caretIndex = await JsInfiniBlazor.TextSelection.GetStartIndexAsync(EditorContext.InputElementRef);
        if (!TextEditor.TryGetCaretLine(EditorContext.TextSource, caretIndex, out Range lineRange)) return;

        Logger.Warning("{lineRange}", lineRange);
        await JsInfiniBlazor.TextSelection.SetRangeAsync(EditorContext.InputElementRef, lineRange);
    }
}