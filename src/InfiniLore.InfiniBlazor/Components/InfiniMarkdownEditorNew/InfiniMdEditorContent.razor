@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@using CodeOfChaos.Extensions.Debouncers

@* ReSharper disable once CheckNamespace *@
@namespace InfiniLore.InfiniBlazor.Components
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@inherits InfiniMdEditorComponentBase
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<div class="@Class border-2 border-red-500 flex">
    <textarea 
        class="w-full h-full  overflow-y-auto infini-scrollbar"
        value="@TextAreaValue"
        @ref="EditorContext.ContentRef"
        @oninput="async args => await OnInputAsyncDebounced.InvokeDebouncedAsync(args)"
        @onkeydown="async args => await OnKeyDownAsyncDebounced.InvokeDebouncedAsync(args)"
    >

    </textarea>
</div>
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@
@code {
    private string? TextAreaValue { get; set; } = string.Empty;
    private ThrottledDebouncer<ChangeEventArgs> OnInputAsyncDebounced { get; set; } = ThrottledDebouncer<ChangeEventArgs>.Empty;
    private Debouncer<KeyboardEventArgs> OnKeyDownAsyncDebounced { get; set; } = Debouncer<KeyboardEventArgs>.Empty;
    
    // -----------------------------------------------------------------------------------------------------------------
    // Component lifetime Methods
    // -----------------------------------------------------------------------------------------------------------------
    protected override void OnInitialized() {
        base.OnInitialized();

        OnInputAsyncDebounced = ThrottledDebouncer<ChangeEventArgs>.FromDelegate(OnInputAsync, 100, 300);
        OnKeyDownAsyncDebounced = Debouncer<KeyboardEventArgs>.FromDelegate(OnKeyDownAsync);
    }

    protected override void OnParametersSet() {
        base.OnParametersSet();

        TextAreaValue = EditorContext.TextSource.Text;
    }

    // -----------------------------------------------------------------------------------------------------------------
    // Methods
    // -----------------------------------------------------------------------------------------------------------------
    private async Task OnInputAsync(ChangeEventArgs args) {
        if (EditorContext.IsLocked) return;
        if (args.Value is not string source) return;
        await EditorContext.UpdateSource(source).ConfigureAwait(false);
    }
    
    private Task OnKeyDownAsync(KeyboardEventArgs args) {
        return Task.CompletedTask;
    }
}