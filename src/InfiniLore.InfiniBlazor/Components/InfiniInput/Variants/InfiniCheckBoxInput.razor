@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@

@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@inherits InfiniInputBase
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<InfiniInputLayout Component="@this">
    <InfiniSpacer/>
    <div class="flex flex-col gap-2">
        @foreach (ICheckBoxData data in Data) {
            <div class="flex flex-row gap-2">
                <InfiniCheckbox @bind-IsChecked="data.IsChecked"></InfiniCheckbox>
                @if (data.Label.IsNotNullOrWhiteSpace()) {
                    <InfiniLabel>@data.Label</InfiniLabel>
                }
            </div>
        }

    </div>
</InfiniInputLayout>
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@

@code {
    [Parameter] public IEnumerable<ICheckBoxData> Data { get; set; } = Array.Empty<ICheckBoxData>();
}
