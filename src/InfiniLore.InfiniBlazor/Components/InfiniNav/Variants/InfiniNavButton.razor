@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@namespace InfiniLore.InfiniBlazor.Components
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@inherits InfiniNavItemBase
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
@* ReSharper disable CSharpWarnings::CS8974 *@
<button @onclick="@Callback" class="@ContainerClasses cursor-pointer">
    <InfiniNavItem Text="@Text" Icon="@Icon" Class="@Class">
        @ChildContent
    </InfiniNavItem>
</button>
@* ReSharper restore CSharpWarnings::CS8974 *@
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@
@code {
    [Parameter] public EventCallback<MouseEventArgs> OnClick  { get; set; }
    
    // -----------------------------------------------------------------------------------------------------------------
    // Methods
    // -----------------------------------------------------------------------------------------------------------------
    private async Task Callback() {
        SubMenuContext?.OnSubItemPressed?.Invoke();
        await OnClick.InvokeAsync();
    }
}

