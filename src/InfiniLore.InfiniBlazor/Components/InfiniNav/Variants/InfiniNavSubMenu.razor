@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@namespace InfiniLore.InfiniBlazor.Components
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@using InfiniLore.Lucide
@inherits InfiniNavItemBase
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<CascadingValue Value="@(Depth + 1)">
    <div class="@OrientationClasses" style="anchor-name: @($"--{Id:N}")">
        <button @onclick="OnClick" class="flex w-full cursor-pointer">
            <div class="@ContainerClassesNoHover w-full grow">
                <div class="flex grow w-full">
                    <InfiniNavItem Text="@Text" Icon="@IconName"/>
                </div>
            </div>
        </button>

        <div class="@AnchoredClasses @(IsMenuOpened ? ZIndex.NavSubMenuItem : ZIndex.Zero) absolute" style="position-anchor:  @($"--{Id:N}")">
            <CascadingValue Value="MenuContext" IsFixed="true">
                <div
                    class="@ConcatClasses(TransitionClasses, BorderClasses) infini-bg-(--nav) border-(--border)">
                    @ChildContent
                </div>
            </CascadingValue>
        </div>
    </div>
</CascadingValue>

@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@

@code {
    [CascadingParameter] public int Depth { get; set; }
    [Parameter] public bool ReverseDirection { get; set; }
    [Parameter] public bool IgnoreCascadeCollapsedState { get; set; }
    private readonly Guid Id = Guid.CreateVersion7();

    private bool IsMenuOpened { get; set; }
    private NavSubMenuContext? MenuContext { get; set; }

    private string IconName => Icon ?? NavBarLocation switch {
        NavBarLocation.Top => LucideNames.ChevronDown,
        NavBarLocation.Left => LucideNames.ChevronRight,
        NavBarLocation.Right => LucideNames.ChevronLeft,
        NavBarLocation.Bottom => LucideNames.ChevronUp,
        _ => string.Empty
    };

    private string OrientationClasses => NavBarLocation switch {
        NavBarLocation.Top => "flex mt-px px-[2px]",
        NavBarLocation.Left => "flex w-full",
        NavBarLocation.Right => "flex w-full px-px",
        NavBarLocation.Bottom => "flex mb-px px-px",
        _ => string.Empty
    };

    private string AnchoredClasses => (Depth, NavBarLocation, ReverseDirection) switch {
        (0, NavBarLocation.Top, _) => "anchored-bottom",
        (0, NavBarLocation.Left, _) => "anchored-right-span-bottom -mt-px",
        (0, NavBarLocation.Right, _) => "anchored-left-span-bottom -mt-px",
        (0, NavBarLocation.Bottom, _) => "anchored-top",

        (not 0, NavBarLocation.Top, false) => "anchored anchored-right-span-bottom",
        (not 0, NavBarLocation.Top, true) => "anchored anchored-left-span-bottom",
        (not 0, NavBarLocation.Bottom, false) => "anchored anchored-right-span-bottom",
        (not 0, NavBarLocation.Bottom, true) => "anchored anchored-left-span-bottom",
        (not 0, NavBarLocation.Right, false) => "anchored anchored-left-span-bottom",
        (not 0, NavBarLocation.Right, true) => "anchored anchored-left-span-top",
        (not 0, NavBarLocation.Left, false) => "anchored anchored-right-span-top",
        (not 0, NavBarLocation.Left, true) => "anchored anchored-right-span-top",

        _ => "anchored-bottom/anchor-nav-bar-menu"
    };

    private string BorderClasses => (Depth, NavBarLocation, ReverseDirection) switch {
        (0, NavBarLocation.Top, _) => "rounded-b-md border-b border-l border-r",
        (not 0, NavBarLocation.Top, false) => "rounded-r-md border-t border-b border-r",
        (not 0, NavBarLocation.Top, true) => "rounded-l-md border-t border-b border-l",
        (_, NavBarLocation.Left, _) => "rounded-r-md border-t border-b border-r",
        (_, NavBarLocation.Right, _) => "rounded-l-md border-t border-b border-l",
        (0, NavBarLocation.Bottom, _) => "rounded-t-md border-t border-l border-r",
        (not 0, NavBarLocation.Bottom, false) => "rounded-r-md border-t border-b border-r",
        (not 0, NavBarLocation.Bottom, true) => "rounded-l-md border-t border-b border-l",
        _ => "border rounded-md"
    };

    private string TransitionClasses => ConcatClasses(
        "transition-all duration-300",
        IsMenuOpened
            ? "opacity-100 scale-100 pointer-events-auto"
            : "opacity-0 scale-95 pointer-events-none");

    // -----------------------------------------------------------------------------------------------------------------
    // Methods
    // -----------------------------------------------------------------------------------------------------------------
    protected override void OnParametersSet() {
        // shh, stupid way of doing this, but it works
        MenuContext = new NavSubMenuContext(
            OnChildPressed,
            IgnoreCascadeCollapsedState
        );
    }

    private void OnClick() {
        IsMenuOpened = !IsMenuOpened;
        StateHasChanged();
    }

    private void OnChildPressed() {
        IsMenuOpened = false;
        SubMenuContext?.OnSubItemPressed?.Invoke();// ensures that multiple deeply nested states are all hidden at once
        InvokeAsync(StateHasChanged);
    }
}
