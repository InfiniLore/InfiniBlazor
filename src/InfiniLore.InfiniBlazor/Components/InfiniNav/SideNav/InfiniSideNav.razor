@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@using InfiniLore.InfiniBlazor.JsRuntime
@using InfiniLore.Lucide
@using Microsoft.Extensions.Logging

@namespace InfiniLore.InfiniBlazor.Components
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@inherits InfiniNavBase
@inject IJsRuntimeHelper JsRuntimeHelper
@inject ILogger<InfiniSideNav> Logger
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<CascadingValue Value="MenuCollapsed">
    <aside class="@NavLocationClasses flex-shrink-0 h-full flex flex-col overflow-x-hidden infini-bg-(--sidebar-nav) border-(--sidebar-nav-border)">
        <div class="@(MenuCollapsed ? "w-14" : ClassOpen) px-2 h-full flex flex-col overflow-x-hidden transition-all duration-300">

            <!-- Top Logo and Hamburger -->
            <div
                class="@(MenuCollapsed ? "justify-center" : "justify-between") flex items-center h-12 min-h-[3rem] max-h-[3rem] w-full">
                <div
                    class="@(MenuCollapsed ? "opacity-0 w-0 overflow-hidden px-0" : "opacity-100 w-full px-2") flex items-center h-8 min-h-[2rem] max-h-[2rem] transition-all duration-300">
                    @Header
                </div>

                <!-- Hamburger Menu -->
                <button
                    class="text-(--sidebar-hamburger) h-10 w-10 min-h-[2rem] min-w-[2rem] flex items-center justify-center rounded hover:bg-(--sidebar-nav-hover) hover:text-(--sidebar-nav-text-hover) focus:outline-none"
                    @onclick="ToggleMenu">
                    <LiMenu class="w-6 h-6"/>
                </button>
            </div>

            <!-- Navigation -->
            @if (Body is not null) {
                <InfiniNavBreak/>
                <div class="flex flex-col flex-grow overflow-x-hidden">
                    <div class="@(MenuCollapsed ? "infini-scrollbar-hidden" : "infini-scrollbar") relative flex grow overflow-x-hidden overflow-y-auto mt-2 mb-2">
                        <div
                            class="sticky top-0 left-0 right-0 h-3 bg-gradient-to-b from-black/10 to-transparent pointer-events-none z-10"></div>
                        <nav class="grow flex flex-col space-y-2">
                            @Body
                        </nav>
                        <div
                            class="sticky bottom-0 left-0 right-0 h-3 bg-gradient-to-t from-black/10 to-transparent pointer-events-none z-10"></div>
                    </div>
                </div>
            }

            <!-- Profile Section -->
            @if (Footer is not null) {
                <div class="border-t border-(--sidebar-nav-border) flex overflow-x-hidden shrink-0">
                    <div
                        class="@(MenuCollapsed ? "infini-scrollbar-hidden" : "infini-scrollbar") relative flex grow overflow-x-hidden overflow-y-auto mt-2 mb-2">
                        <div
                            class="sticky top-0 left-0 right-0 h-3 bg-gradient-to-b from-black/10 to-transparent pointer-events-none z-10"></div>
                        <nav class="grow flex flex-col space-y-2">
                            @Footer
                        </nav>
                        <div
                            class="sticky bottom-0 left-0 right-0 h-3 bg-gradient-to-t from-black/10 to-transparent pointer-events-none z-10"></div>
                    </div>
                </div>
            }
        </div>
    </aside>
</CascadingValue>
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@
@code {
    [Parameter] public bool MenuCollapsed { get; set; }

    [Parameter] public RenderFragment? Header { get; set; }
    [Parameter] public RenderFragment? Body { get; set; }
    [Parameter] public RenderFragment? Footer { get; set; }

    [Parameter] public EventCallback<bool> MenuCollapsedChanged { get; set; }

    private string ClassOpen => Size switch {
        Size.Xxs => "w-14",
        Size.Xs => "w-24",
        Size.S => "w-48",
        Size.M => "w-64",
        Size.L => "w-80",
        Size.Xl => "w-96",
        Size.Xxl => "w-112",
        _ => throw new ArgumentOutOfRangeException(nameof(Size), Size, null)
    };

    private const string LocalStorageKey = "SideNavCollapsedState";

    private bool _initialized;

    // -----------------------------------------------------------------------------------------------------------------
    // Methods
    // -----------------------------------------------------------------------------------------------------------------
    protected override async Task OnInitializedAsync() {
        VisualDebugger.InitializeFromUrl();
        
        if (!RendererInfo.IsInteractive) return; // Only try to load state from localStorage in interactive mode
        bool savedState = await JsRuntimeHelper.LocalStorage.TryGetValueAsync<bool>(LocalStorageKey);
        if (!savedState || _initialized) return;

        _initialized = true;
        MenuCollapsed = savedState;
        await MenuCollapsedChanged.InvokeAsync(MenuCollapsed);
        StateHasChanged();
    }

    private async Task ToggleMenu() {
        MenuCollapsed = !MenuCollapsed;
        if (RendererInfo.IsInteractive && !await JsRuntimeHelper.LocalStorage.TrySetValueAsync(LocalStorageKey, MenuCollapsed)) {
            Logger.Warning("Could not store Collapsed menu state to js.LocalStorage");
        } 

        await MenuCollapsedChanged.InvokeAsync(MenuCollapsed);
        await InvokeAsync(StateHasChanged);
    }
}
