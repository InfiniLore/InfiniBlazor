@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@namespace InfiniLore.InfiniBlazor.Components
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@using InfiniLore.Lucide
@inherits InfiniNavItemBase
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<span hidden="@Hidden" class="@Class flex flex-nowrap items-center justify-center">
    @switch (Icon: IconName, Text) {
        case (not null, null): {
            <span class="@IconClasses">
                <LucideIcon Name="@IconName" Size="@IconSize"/>
            </span>
            @ChildContent
            break;
        }

        case (null, not null): {
            <span
                class="@(NavBarCollapsed ? "w-0 opacity-0 delay-0" : "delay-300 w-auto opacity-100") transition-all duration-300 h-6 overflow-hidden">
                <span class="@TextClasses">
                    @Text
                </span>
                @ChildContent
            </span>
            break;
        }

        case (_, _): {
            <span class="@IconClasses">
                <LucideIcon Name="@IconName" Size="@IconSize"/>
            </span>

            <span
                class="@(NavBarCollapsed ? "w-0 opacity-0 delay-0" : "delay-300 w-auto ml-2 opacity-100") transition-all duration-300 h-6 overflow-hidden">
                <span class="@TextClasses">
                    @Text
                </span>
                @ChildContent
            </span>
            break;
        }
    }
</span>
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@
@code {
    // -----------------------------------------------------------------------------------------------------------------
    // Methods
    // -----------------------------------------------------------------------------------------------------------------
    private int IconSize => NavBarSize switch {
        Size.Xxs => 10,
        Size.Xs => 14,
        Size.S => 18,
        Size.M => 24,
        Size.L => 32,
        Size.Xl => 42,
        Size.Xxl => 48,
        _ => 324
    };
    
    private const string IconClasses = "text-(--sidebar-nav-text) flex-shrink-0 group-hover:text-(--sidebar-nav-text-hover)";
    private const string TextClasses = "text-(--sidebar-nav-text) truncate inline-block max-w-[150px] group-hover:text-(--sidebar-nav-text-hover)";
}

