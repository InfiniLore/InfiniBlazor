@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@

@namespace InfiniLore.InfiniBlazor.Components
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@inherits InfiniComponentBase
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
@if (NavBarCollapsed) {
        <div class="h-10 w-10 flex items-center justify-center">
            <InfiniToggleButton 
                DebugColor="DebugColor"
                Value="@Value"
                ValueChanged="@ValueChanged"
                Size="Size.Xxs"
                StopPropagation="true"
                Disabled="@Disabled"
                OnIcon="@OnIcon"
                OffIcon="@OffIcon"
                Class="@ConcatClasses(Class, "transform")"
                Color="@Color"/>
        </div>
} else {
    <div class="@InfiniNavItem.ContainerClassesNoHover flex justify-between items-center h-10">
        <InfiniNavItem DebugColor="DebugColor">
            <Icon>@Icon</Icon>
            <Text>@Text</Text>
        </InfiniNavItem>
        
        <InfiniSpacer DebugColor="DebugColor"/>
        <InfiniToggleButton
            DebugColor="DebugColor"
            Value="@Value"
            ValueChanged="@ValueChanged"
            Size="Size.Xs"
            StopPropagation="true"
            Disabled="@Disabled"
            OnIcon="@OnIcon"
            OffIcon="@OffIcon"
            Class="@ConcatClasses(Class, "ml-2")"
            Color="@Color"/>
    </div>
}

@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@

@code {
    [CascadingParameter] public bool NavBarCollapsed { get; set; }

    [Parameter] public bool Value { get; set; }
    [Parameter] public EventCallback<bool> ValueChanged { get; set; }
    [Parameter] public RenderFragment? Text { get; set; }
    [Parameter] public RenderFragment? Icon { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string? OnIcon { get; set; }
    [Parameter] public string? OffIcon { get; set; }
    [Parameter] public Color Color { get; set; } = Color.Default;
}

