@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@using InfiniLore.InfiniBlazor.JsRuntime
@using Microsoft.Extensions.Logging
@using Microsoft.JSInterop

@namespace InfiniLore.InfiniBlazor.Components
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@inject IJSRuntime JsRuntime
@inject ILogger<InfiniTooltip> Logger
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<div
    @ref="_tooltipRef"
    class="fixed z-1000"
    style="left: @(_left)px; top: @(_top)px">
    <div
        class="@TooltipClasses transform px-3 py-1 infini-bg-(--color-base-90) text-(--color-base-10) text-sm rounded-md transition-opacity duration-200 whitespace-nowrap pointer-events-none before:content-[''] before:absolute before:w-2 before:h-2 before:rotate-45 before:infini-bg-(--color-base-90) drop-shadow-md">
        @Content
    </div>
</div>

@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@

@code {
    [Parameter, EditorRequired] public string Content { get; set; } = "";
    [Parameter] public Anchor Anchor { get; set; } = Anchor.Center | Anchor.Bottom;
    [Parameter] public ElementReference Target { get; set; }

    private ElementReference _tooltipRef;
    private double _left = -1000;
    private double _top = -1000;

    private string TooltipClasses => Anchor switch {
        Anchor.Center | Anchor.Bottom => "before:-top-1 before:left-1/2 before:-translate-x-1/2",
        Anchor.Left | Anchor.Bottom => "before:-top-1 before:left-4",
        Anchor.Right | Anchor.Bottom => "before:-top-1 before:right-4",
        Anchor.Center | Anchor.Top => "before:-bottom-1 before:left-1/2 before:-translate-x-1/2",
        Anchor.Left | Anchor.Top => "before:-bottom-1 before:left-4",
        Anchor.Right | Anchor.Top => "before:-bottom-1 before:right-4",
        Anchor.Left => "before:top-3 before:-right-1",
        Anchor.Right => "before:top-3 before:-left-1",
        _ => "before:-top-1 before:left-1/2 before:-translate-x-1/2"
    };

    // -----------------------------------------------------------------------------------------------------------------
    // Methods
    // -----------------------------------------------------------------------------------------------------------------
    protected override async Task OnAfterRenderAsync(bool firstRender) {
        // TODO Position is broken in WASM
        if (firstRender && RendererInfo.IsInteractive ) {
            await UpdatePosition();
        }
    }


    private async Task UpdatePosition() {
        try {
            var rectSelf = await JsRuntime.InvokeAsync<DomRect>("getBoundingClientRect", _tooltipRef);
            var rect = await JsRuntime.InvokeAsync<DomRect>("getBoundingClientRect", Target);
            
            Logger.Warning("SELF: X: {a} \nY: {a} \nWidth: {a} \nHeight: {a} \nTop: {a} \nRight: {a} \nBottom: {a} \nLeft: {a}", 
                rectSelf.X,
                rectSelf.Y,
                rectSelf.Width,
                rectSelf.Height,
                rectSelf.Top,
                rectSelf.Right,
                rectSelf.Bottom,
                rectSelf.Left);
            
            Logger.Warning("RECT: X: {a} \nY: {a} \nWidth: {a} \nHeight: {a} \nTop: {a} \nRight: {a} \nBottom: {a} \nLeft: {a}", 
                rect.X,
                rect.Y,
                rect.Width,
                rect.Height,
                rect.Top,
                rect.Right,
                rect.Bottom,
                rect.Left);
            
            var sizeTriangle = 8;

            (_left, _top) = Anchor switch {
                // Bottom positions
                Anchor.Center | Anchor.Bottom => (
                    rect.Left + rect.Width / 2 - rectSelf.Width /2 ,
                    rect.Top + rect.Height + sizeTriangle
                ),
                Anchor.Left | Anchor.Bottom => (
                    rect.Left,
                    rect.Bottom + sizeTriangle
                ),
                Anchor.Right | Anchor.Bottom => (
                    rect.Right - rectSelf.Width,
                    rect.Bottom + sizeTriangle
                ),

                // Top positions
                Anchor.Center | Anchor.Top => (
                    rect.Left + rect.Width / 2 - rectSelf.Width /2 ,
                    rect.Top - rectSelf.Height - sizeTriangle
                ),
                Anchor.Left | Anchor.Top => (
                    rect.Left,
                    rect.Top - rectSelf.Height - sizeTriangle
                ),
                Anchor.Right | Anchor.Top => (
                    rect.Right - rectSelf.Width,
                    rect.Top - rectSelf.Height - sizeTriangle
                ),

                // Side positions
                Anchor.Left => (
                    rect.Left - rectSelf.Width - sizeTriangle,
                    rect.Top + rect.Height / 2 - rectSelf.Height / 2
                ),
                Anchor.Right => (
                    rect.Right + sizeTriangle,
                    rect.Top + rect.Height / 2 - rectSelf.Height / 2
                ),


                _ => (
                    rect.Left + (rect.Width - rectSelf.Width) / 2,
                    rect.Bottom + sizeTriangle
                )
            };
            
            Logger.Error("Left: {l} \nTop: {r}", _left, _top);
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception e) {
            Console.WriteLine(e);
        }
    }

}
