@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@namespace InfiniLore.InfiniBlazor.Components
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@inherits InfiniComponentBase
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
@if (Context.SelectedTabId == TabName) {
    @ChildContent
}

@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@
@code {
    [EditorRequired, Parameter] public string TabName { get; set; } = string.Empty;
    [CascadingParameter] public InfiniTabContainerContext Context { get; set; } = null!;

    private bool _isRegistered;
    
    protected override void OnInitialized() {
        if (!_isRegistered) {
            Context.RegisterPage(TabName);
            _isRegistered = true;
        }
        Context.OnTabSelected += StateHasChanged;
    }

    public override async ValueTask DisposeAsync() {
        await base.DisposeAsync();
        Context.UnregisterPage(TabName);
        Context.OnTabSelected -= StateHasChanged;
    }
}
