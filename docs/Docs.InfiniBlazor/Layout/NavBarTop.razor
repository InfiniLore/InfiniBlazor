@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@using InfiniLore.InfiniBlazor
@using InfiniLore.InfiniBlazor.Components
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@rendermode InfiniRenderModeProvider.InfiniRenderMode
@inherits InfiniNavBarBase
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<InfiniNavBar Location="NavBarLocation.Top" Size="Size.L" Class="@Class">
    <InfiniNavCollapseButton 
        State="CollapsedState"
        StateChanged="@UpdateCollapse"/>
    
    <InfiniNavLink
        Href="/"
        Text="InfiniBlazor Docs"
        Class="font-bold"
    />
    
    <InfiniSpacer/>
    
    <InfiniNavLink
        Href="https://github.com/InfiniLore/InfiniBlazor"
        Icon="github"
    />
    
</InfiniNavBar>
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@

@code {
    [Parameter] public bool CollapsedState { get; set; }
    [Parameter] public EventCallback<bool> CollapsedStateChanged { get; set; }

    private async Task UpdateCollapse(bool state) {
        CollapsedState = state;
        await CollapsedStateChanged.InvokeAsync(state);
    }
}