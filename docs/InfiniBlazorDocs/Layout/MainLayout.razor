@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@using global::InfiniBlazor
@inherits LayoutComponentBase
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<InfiniThemeManager/>
<InfiniDialogManager/>

<InfiniLayout Layout="NavLayout.TopPrimary">
    <Left>
        <NavBarLeft @bind-CollapsedState="@CollapsedState"/>
    </Left>
    <Top>
        <NavBarTop @bind-CollapsedState="@CollapsedState"/>
    </Top>
    
    <Body>
        <InfiniToastManager/>
        @Body
    </Body>
</InfiniLayout>

<div id="blazor-error-ui" class="hidden fixed bottom-0 left-0 w-full bg-yellow-100 shadow-md p-3 pl-5 @ZIndex.BlazorError">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss cursor-pointer absolute right-3 top-2">🗙</a>
</div>

@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@
@code {
    [Parameter] public bool CollapsedState { get; set; }
    [Parameter] public EventCallback<bool> CollapsedStateChanged { get; set; }
}