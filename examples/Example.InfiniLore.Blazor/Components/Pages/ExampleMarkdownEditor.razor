@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@using InfiniLore.Blazor.Markdown
@using InfiniLore.Blazor.Markdown.Components
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@page "/markdown-test"
@rendermode InteractiveServer
@inject IMarkdownParser MarkdownParser
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<div class="flex space-x-4">
    <input type="text" class="w-1/2 h-full p-4 border-2 border-gray-300 rounded-lg" @bind="MarkdownText">
    <div class="w-1/2 h-16 p-4 border-2 border-red-300 rounded-lg">@MarkdownOutput</div>
</div>

<MarkdownEditor></MarkdownEditor>
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@

@code {
    private string _markdownText = string.Empty;

    private string MarkdownText {
        get => _markdownText;
        set {
            _markdownText = value;
            string editedText = MarkdownParser.Parse(_markdownText);
            MarkdownOutput = new MarkupString($"<p>{editedText}</p>");
        }
    }
    
    private MarkupString MarkdownOutput { get; set; }
}