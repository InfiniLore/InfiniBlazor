@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports *@
@* ------------------------------------------------------------------------------------------------------------------ *@
@using InfiniLore.InfiniBlazor.Theming
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@rendermode InteractiveServer
@inject IThemeSelector ThemeSelector
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html *@
@* ------------------------------------------------------------------------------------------------------------------ *@
<CollapsibleMenu @bind-IsMenuCollapsed="@IsMenuCollapsed" Width="w-64">
    <Header>
        <a href="/"
           class="@(!IsMenuCollapsed ? "text-1xl font-bold text-(--color-base-00) hover:text-(--color-accent) no-underline" : "hidden")">
            InfiniBlazor
        </a>
    </Header>

    <NavigationMenu>
        <CollapsibleMenuButton Href="/markdown-dual">
            <Icon> <LiSignature/></Icon>
            <Text>Markdown Example</Text>
        </CollapsibleMenuButton>
        <CollapsibleMenuButton Href="/markdown-rolling">
            <Icon><LiIndentIncrease/></Icon>
            <Text>Rolling Markdown Example</Text>
        </CollapsibleMenuButton>
    </NavigationMenu>

    <Footer>
        <CollapsibleMenuButton Href="https://github.com/InfiniLore/infinilore.infiniblazor">
            <Icon><LiPackage/></Icon>
            <Text>Github</Text>
        </CollapsibleMenuButton>

        @* DEBUG *@
        <CollapsibleMenuButton OnClickCallback="@(() => SwitchTheme())">
            <Icon><LiPalette/></Icon>
            <Text>Switch Theme</Text>
        </CollapsibleMenuButton>

        <CollapsibleMenuButton OnClickCallback="@(() => ThemeSelector.TryToggleDarkAndLightMode())">
            <Icon><LiSun/></Icon>
            <Text>Switch Mode</Text>
        </CollapsibleMenuButton>
    </Footer>


</CollapsibleMenu>

@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code *@
@* ------------------------------------------------------------------------------------------------------------------ *@
@code {
    private string Theme { get; set; } = "default";
    private bool IsMenuCollapsed { get; set; }// Tracks whether the menu is collapsed

    // -----------------------------------------------------------------------------------------------------------------
    // Methods
    // -----------------------------------------------------------------------------------------------------------------
    private void SwitchTheme() {
        Theme = Theme switch {
            "default" => "anna",
            "anna" => "default",
            _ => Theme
        };
        ThemeSelector.TrySelectTheme(Theme);
    }
}
