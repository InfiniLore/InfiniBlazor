@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@using InfiniLore.InfiniBlazor.Markdown
@using System.Text.Encodings.Web
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@page "/markdown-dual"
@rendermode InteractiveServer
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<InfiniPage>
    <InfiniSection Class="flex flex-col h-screen gap-2">
        <InfiniHeading1>Markdown Editor Example</InfiniHeading1>
        <InfiniMarkdownEditor @bind-Source="@TextSource0"/>
        
        <InfiniCodeBlock Content="@TextSource0.Text"/>
    </InfiniSection>
    
    <InfiniSection Class="flex flex-col h-screen gap-2">
        <InfiniHeading1>Markdown Editor Example</InfiniHeading1>
        <InfiniMarkdownEditor @bind-Source="@TextSource1" ShowPreview="false"/>
        
        <InfiniCodeBlock @bind-Content="@TextSource1.Text"/>
    </InfiniSection>
</InfiniPage>

@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@
@code {
    private ITextSource TextSource0 { get; set; } = new TextSource();
    private ITextSource TextSource1 { get; set; } = new TextSource() {
        Text = "Some Initial text..."
    };
}

