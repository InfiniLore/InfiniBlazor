@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@using InfiniLore.InfiniBlazor.Markdown
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@page "/markdown-dual"
@rendermode InteractiveServer
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<InfiniPage>
    <InfiniSection Class="flex flex-col h-screen">
        <InfiniHeading1>Markdown Editor Example</InfiniHeading1>
        <InfiniMarkdownEditor Source="@TextSource"/>
    </InfiniSection>
    
    <InfiniSection Class="flex flex-col h-screen">
        <InfiniHeading1>Markdown Editor Example</InfiniHeading1>
        <InfiniMarkdownEditor Source="@TextSource" ShowPreview="false"/>
    </InfiniSection>
</InfiniPage>

@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@
@code {
    private ITextSource TextSource { get; } = new TextSource();
}

