@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@using InfiniLore.InfiniBlazor.Markdown
@using System.Text.RegularExpressions
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@page "/markdown-rolling"
@rendermode InteractiveServer
@inject IMarkdownParser<string, string> Parser
@inject ILogger<ExampleMarkdownEditor> Logger
@inject IJSRuntime JsRuntime
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<div class="editor-container">
    @for (int i = 0; i < Paragraphs.Count; i++) {
        int index = i;
        if (index == _activeParagraphIndex) {
            <div class="paragraph-editor"
                 contenteditable="true"
                 spellcheck="true"
                 @ref="_editableDiv"
                 @oninput="@(e => OnParagraphInput(e, index))"
                 @onkeydown="@(e => OnKeyDown(e, index))"
                 @onblur="@(() => OnParagraphBlur(index))"></div>

        } else {
            <div class="markdown-content" @onclick="@(() => ActivateParagraph(index))">
                @((MarkupString)GetParsedParagraph(index))
            </div>
        }
    }
</div>
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@
@code {
    private readonly List<string> Paragraphs = new() { "" };
    private int _activeParagraphIndex;
    private ElementReference _editableDiv;
    private bool _isActivating;
    private bool _pendingActivation;
    private int _pendingIndex;

    // -----------------------------------------------------------------------------------------------------------------
    // Methods
    // -----------------------------------------------------------------------------------------------------------------
    private Task ActivateParagraph(int index) {
        if (_isActivating) return Task.CompletedTask;

        try {
            _isActivating = true;
            _activeParagraphIndex = index;
            _pendingActivation = true;
            _pendingIndex = index;
            StateHasChanged();
        }
        finally {
            _isActivating = false;
        }

        return Task.CompletedTask;
    }
    
    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (_pendingActivation) {
            _pendingActivation = false;
            await Task.Delay(10);// Small delay to ensure DOM is ready
            await JsRuntime.InvokeVoidAsync("setElementText", _editableDiv, Paragraphs[_pendingIndex]);
        }
    }

    private Task OnParagraphBlur(int index) {
        // If the paragraph is empty, and it's not the last one, remove it
        if (string.IsNullOrWhiteSpace(Paragraphs[index]) && Paragraphs.Count > 1) {
            Paragraphs.RemoveAt(index);
            _activeParagraphIndex = Math.Max(0, index - 1);
        }
        // If we're at the end of the last paragraph, add a new one
        else if (index == Paragraphs.Count - 1) {
            Paragraphs.Add("");
            _activeParagraphIndex = Paragraphs.Count - 1;
        }

        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task OnParagraphInput(ChangeEventArgs _, int index) {
        string text = await JsRuntime.InvokeAsync<string>("getInnerText", _editableDiv);

        // Don't split if the text starts with list markers, table markers, or is part of a code block
        bool shouldSplit = !text.StartsWith("```")
            && !text.StartsWith("|")
            && !text.StartsWith("-")
            && !text.StartsWith("*")
            && !text.StartsWith("+")
            && !text.StartsWith(">")
            && !Regex.IsMatch(text, @"^\d+\.");

        if (shouldSplit && text.Contains("\n\n")) {
            string[] parts = text.Split(new[] { "\n" }, StringSplitOptions.None);

            // Update current paragraph
            Paragraphs[index] = parts[0];

            // Insert new paragraphs after the current one
            Paragraphs.InsertRange(index + 1, parts.Skip(1));

            // Set the active paragraph to the last inserted one
            _activeParagraphIndex = index + parts.Length - 1;
            await ActivateParagraph(_activeParagraphIndex);
        } else {
            Paragraphs[index] = text;
        }

        StateHasChanged();
    }

    private async Task OnKeyDown(KeyboardEventArgs e, int index) {
        if (e.Key == "Enter") {
            string text = await JsRuntime.InvokeAsync<string>("getInnerText", _editableDiv);

            if (e.ShiftKey) {
                // For Shift+Enter, update the current paragraph with the line break
                Paragraphs[index] = text + "\n";
                await ActivateParagraph(index); // Stay in the same paragraph
                return;
            }

            // Create a new paragraph
            string[] lines = text.Split('\n');
            string currentLine = lines.Last();

            // Update the current paragraph to exclude the last line
            Paragraphs[index] = string.Join("\n", lines.Take(lines.Length - 1));

            // Insert a new paragraph with the last line
            Paragraphs.Insert(index + 1, currentLine);
            await ActivateParagraph(index + 1);
        }
    }


    private string GetParsedParagraph(int index) {
        string paragraph = Paragraphs[index];
        return Parser.TryParseAsync(paragraph).Result ?? string.Empty;
    }

    protected override void OnInitialized() {
        // Initialize with an empty paragraph
        if (!Paragraphs.Any()) {
            Paragraphs.Add("");
        }
    }
}

