@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@using Infinilore.InfiniBlazor
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@page "/html"
@rendermode InteractiveServer
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<InfiniPage>
    <InfiniSection>
        <InfiniToggleButton 
            @bind-Value="isEnabled"
            OnIcon="sun"
            OffIcon="moon"
            Size="Size.Md"
            Tooltip="Toggle theme"
        ></InfiniToggleButton>
        <InfiniToggleButton 
            @bind-Value="isEnabled"
            OnIcon="sun"
            OffIcon="moon"
            Size="Size.Sm"
            Tooltip="Toggle theme"
        ></InfiniToggleButton>
        <InfiniToggleButton 
            @bind-Value="isEnabled"
            OnIcon="sun"
            OffIcon="moon"
            Size="Size.Lg"
            Tooltip="Toggle theme"
        ></InfiniToggleButton>
    </InfiniSection>
    
    <SectionTextInput/>
    
    <SectionCodeBlock/>
    
    <SectionHeadings/>
    
    <SectionSpacers/>
</InfiniPage>
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@
@code {
    bool isEnabled;
}
