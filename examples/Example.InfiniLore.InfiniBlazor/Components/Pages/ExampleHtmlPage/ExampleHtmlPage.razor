@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@using Infinilore.InfiniBlazor
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@page "/html"
@rendermode InteractiveServer
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<InfiniPage>
    <InfiniSection>
        <InfiniToggleButton
            @bind-Value="isEnabled"
            OnIcon="sun"
            OffIcon="moon"
            Size="Size.Xxs"
        />
        
        <InfiniToggleButton
            @bind-Value="isEnabled"
            OnIcon="sun"
            OffIcon="moon"
            Size="Size.Xs"
        />
        
        <InfiniToggleButton
            @bind-Value="isEnabled"
            OnIcon="sun"
            OffIcon="moon"
            Size="Size.S"
        />
        <InfiniToggleButton
            @bind-Value="isEnabled"
            OnIcon="sun"
            OffIcon="moon"
            Size="Size.M"
        />
        <InfiniToggleButton
            @bind-Value="isEnabled"
            OnIcon="sun"
            OffIcon="moon"
            Size="Size.L"
        />
        <InfiniToggleButton
            @bind-Value="isEnabled"
            OnIcon="sun"
            OffIcon="moon"
            Size="Size.Xl"
        />
        <InfiniToggleButton
            @bind-Value="isEnabled"
            OnIcon="sun"
            OffIcon="moon"
            Size="Size.Xxl"
        />
    </InfiniSection>

    <SectionTextInput/>

    <SectionCodeBlock/>

    <SectionHeadings/>

    <SectionSpacers/>
</InfiniPage>
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@

@code {
    bool isEnabled;
}
