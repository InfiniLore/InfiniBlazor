@using JetBrains.Annotations
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@

@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@rendermode InteractiveServer
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<InfiniSection Class="flex flex-col gap-4">
    <InfiniHeading3>Toggle Buttons</InfiniHeading3>

    <InfiniToggleButton
        @bind-Value="_isEnabled"
        OnIcon="sun"
        OffIcon="moon"
        Size="Size.Xxs"
    />

    <InfiniToggleButton
        @bind-Value="_isEnabled"
        OnIcon="sun"
        OffIcon="moon"
        Size="Size.Xs"
    />

    <InfiniToggleButton
        @bind-Value="_isEnabled"
        OnIcon="sun"
        OffIcon="moon"
        Size="Size.S"
    />
    <InfiniToggleButton
        @bind-Value="_isEnabled"
        OnIcon="sun"
        OffIcon="moon"
        Size="Size.M"
    />
    <InfiniToggleButton
        @bind-Value="_isEnabled"
        OnIcon="sun"
        OffIcon="moon"
        Size="Size.L"
    />
    <InfiniToggleButton
        @bind-Value="_isEnabled"
        OnIcon="sun"
        OffIcon="moon"
        Size="Size.Xl"
    />
    <InfiniToggleButton
        @bind-Value="_isEnabled"
        OnIcon="sun"
        OffIcon="moon"
        Size="Size.Xxl"
    />

</InfiniSection>
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@
@code {
    [UsedImplicitly] bool _isEnabled;
}
