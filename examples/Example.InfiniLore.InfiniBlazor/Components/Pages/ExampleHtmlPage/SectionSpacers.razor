@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@using InfiniLore.InfiniBlazor.Debugger
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@rendermode InteractiveServer
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<InfiniSection>
    <InfiniHeading2>Spacers Vertical</InfiniHeading2>
    <InfiniSpacerVertical DebugColor="DebugColor.Red" Spacing="Size.Xxs"/>
    <InfiniSpacerVertical DebugColor="DebugColor.Orange" Spacing="Size.Xs"/>
    <InfiniSpacerVertical DebugColor="DebugColor.Yellow" Spacing="Size.S"/>
    <InfiniSpacerVertical DebugColor="DebugColor.Green" Spacing="Size.M"/>
    <InfiniSpacerVertical DebugColor="DebugColor.Cyan" Spacing="Size.L"/>
    <InfiniSpacerVertical DebugColor="DebugColor.Blue" Spacing="Size.Xl"/>
    <InfiniSpacerVertical DebugColor="DebugColor.Purple" Spacing="Size.Xxl"/>
</InfiniSection>

<InfiniSection>
    <InfiniHeading2>Spacers Horizontal</InfiniHeading2>
    <div class="h-12 flex">
        <InfiniSpacerHorizontal DebugColor="DebugColor.Red" Spacing="Size.Xxs"/>
        <InfiniSpacerHorizontal DebugColor="DebugColor.Orange" Spacing="Size.Xs"/>
        <InfiniSpacerHorizontal DebugColor="DebugColor.Yellow" Spacing="Size.S"/>
        <InfiniSpacerHorizontal DebugColor="DebugColor.Green" Spacing="Size.M"/>
        <InfiniSpacerHorizontal DebugColor="DebugColor.Cyan" Spacing="Size.L"/>
        <InfiniSpacerHorizontal DebugColor="DebugColor.Blue" Spacing="Size.Xl"/>
        <InfiniSpacerHorizontal DebugColor="DebugColor.Purple" Spacing="Size.Xxl"/>
        <InfiniSpacerHorizontal DebugColor="DebugColor.Pink" Direction="SpacerDirection.Grow" />
    </div>
</InfiniSection>
