@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@using InfiniLore.InfiniBlazor
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@page "/html"
@rendermode InfiniRenderModeProvider.InfiniRenderMode
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<InfiniPage Title="HTML" Class="p-4">
    <InfiniSection Class="gap-4 w-full min-h-full">
        <InfiniTabContainer>
            <InfiniTabContent TabName="Buttons">
                <SectionButtons/>
            </InfiniTabContent>
            <InfiniTabContent TabName="ToggleButtons">
                <SectionToggleButtons/>
            </InfiniTabContent>
            <InfiniTabContent TabName="Input">
                <SectionInput/>
            </InfiniTabContent>
            <InfiniTabContent TabName="CodeBlock">
                <SectionCodeBlock/>
            </InfiniTabContent>
            <InfiniTabContent TabName="Headings">
                <SectionHeadings/>
            </InfiniTabContent>
            <InfiniTabContent TabName="Spacers">
                <SectionSpacers/>
            </InfiniTabContent>
            <InfiniTabContent TabName="CheckBoxes">
                <SectionCheckBoxes/>
            </InfiniTabContent>
            <InfiniTabContent TabName="Tags">
                <SectionTags/>
            </InfiniTabContent>
        </InfiniTabContainer>
    </InfiniSection>
</InfiniPage>
