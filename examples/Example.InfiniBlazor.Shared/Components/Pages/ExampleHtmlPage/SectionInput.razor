@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@

@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@rendermode InteractiveAuto
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<!-- Basic Text Input Example -->
<InfiniSection>
    <InfiniHeading3>Basic Text Input</InfiniHeading3>
    <div class="space-y-4">
        <InfiniTextInput
            @bind-Value="@BasicExample.Value"
            OnChange="BasicExample.OnChanged"
            Placeholder="Type something..."/>

        <div class="text-sm space-y-1">
            <p>Bound Value: @BasicExample.Value</p>
            <p>OnChanged Value: @BasicExample.OnChangedValue</p>
        </div>
    </div>
</InfiniSection>

<!-- Text Input with Submit Button -->
<InfiniSection>
    <InfiniHeading3>Text Input with Submit</InfiniHeading3>
    <div class="space-y-4 w-1/2" >
        <InfiniToggleInput
            Label="Toggle Enabled State"
            Value="@TextInputDisabled"
            ValueChanged="@HandleToggleChanged">
            @TextInputDisabled
        </InfiniToggleInput>

        <InfiniTextInput
            Label="Do something"
            @bind-Value="@SubmitExample.Value"
            Placeholder="Type something else and submit..."
            Disabled="TextInputDisabled"/>

        <InfiniTextInput
            Label="Do something with a long label... bla bla bla blabla bla bla blabla bla bla blabla bla bla blabla bla bla blabla bla bla blabla bla bla bla bla bla bla bla bla"
            LabelLocation="LabelLocation.Left"
            @bind-Value="@SubmitExample.Value"
            Placeholder="Type something else and submit..."
            Disabled="TextInputDisabled">
            <InfiniButton OnClick="SubmitExample.OnSubmit">Submit</InfiniButton>
        </InfiniTextInput>

        <InfiniFileInput
            Label="Upload Files"
            Accept=".png,.jpg,.jpeg"
            AllowMultipleFiles
            Disabled="TextInputDisabled"
            OnFilesChanged="HandleFilesChanged"
            Placeholder="Choose documents..."/>
        
        <InfiniButtonInput Label="Does Soemthing">
            Submit
        </InfiniButtonInput>

        <div class="text-sm space-y-1">
            <p>Bound Value: @SubmitExample.Value</p>
            <p>Submitted Value: @SubmitExample.SubmittedValue</p>

            @if (SelectedFiles is not null && SelectedFiles.Any()) {
                <div class="mt-2 space-y-2">
                    <p class="text-sm font-medium">Selected Files:</p>
                    <div class="space-y-1">
                        @foreach (IBrowserFile file in SelectedFiles) {
                            <div class="flex items-center gap-2 text-sm p-2 bg-(--color-base-95) rounded">
                                <span class="font-medium">@file.Name</span>
                                <span class="text-(--color-base-40)">(@(file.Size / 1024.0) KB)</span>
                            </div>
                        }
                    </div>
                </div>
            }

        </div>
        
        

    </div>
</InfiniSection>

<!-- Text Input with Label -->
<InfiniSection>
    <InfiniHeading3>Text Input with Submit</InfiniHeading3>
    <div class="space-y-4">
        <InfiniTextInput
            @bind-Value="@SubmitExample.Value"
            Placeholder="Type something else and submit..."
            Label="Test Example"
        >
            <InfiniButton Variant="ButtonVariant.Primary" OnClick="SubmitExample.OnSubmit">Submit</InfiniButton>
        </InfiniTextInput>

        <div class="text-sm space-y-1">
            <p>Bound Value: @SubmitExample.Value</p>
            <p>Submitted Value: @SubmitExample.SubmittedValue</p>
        </div>
    </div>
</InfiniSection>

<!-- Form Inputs Example -->
<InfiniSection>
    <InfiniHeading3>Form Inputs</InfiniHeading3>
    <div class="space-y-4">
        <InfiniTextInput
            Type="email"
            LabelLocation="LabelLocation.OnTop"
            Label="Email"
            Value="@FormExample.Email"
            ValueChanged="FormExample.HandleEmailChange"
            ValidationMessage="@FormExample.ValidationMessage"
            Placeholder="Enter email">
        </InfiniTextInput>

        <InfiniTextInput
            Label="Password"
            LabelLocation="LabelLocation.Left"
            Type="password"
            Value="@FormExample.Password"
            ValueChanged="@(value => FormExample.Password = value)"
            Placeholder="Enter password"/>
    </div>
</InfiniSection>


@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@

@code {
    private BasicInputExample BasicExample { get; } = new();
    private SubmitInputExample SubmitExample { get; } = new();
    private FormInputExample FormExample { get; } = new();

    private bool TextInputDisabled { get; set; }

    private IEnumerable<IBrowserFile>? SelectedFiles { get; set; }

    // -----------------------------------------------------------------------------------------------------------------
    // Models
    // -----------------------------------------------------------------------------------------------------------------
    private async Task HandleToggleChanged(bool value) {
        TextInputDisabled = value;
        await InvokeAsync(StateHasChanged);
    }

    private sealed class BasicInputExample {
        public string? Value { get; set; }
        public string? OnChangedValue { get; private set; }

        public void OnChanged(ChangeEventArgs args) {
            if (args.Value is string value) {
                OnChangedValue = value;
            }
        }
    }

    private sealed class SubmitInputExample {
        public string? Value { get; set; }
        public string? SubmittedValue { get; private set; }

        public void OnSubmit(MouseEventArgs _) {
            SubmittedValue = Value;
        }
    }

    private sealed class FormInputExample {
        public string? Password { get; set; }
        public string? Email { get; private set; }
        public string? ValidationMessage { get; private set; }

        public void HandleEmailChange(string? value) {
            Email = value;
            ValidationMessage = ValidateEmail(value);
        }

        private static string? ValidateEmail(string? value) => value switch {
            null or "" => "Email is required",
            not null when !value.Contains("@") => "Please enter a valid email address",
            _ => null
        };
    }

    private void HandleFilesChanged(IReadOnlyList<IBrowserFile>? obj) {
        SelectedFiles = obj;
    }
}