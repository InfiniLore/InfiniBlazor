@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@using Microsoft.AspNetCore.Components.Rendering
@using Microsoft.AspNetCore.Components.RenderTree
@using System.Text

@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@inherits ComponentBase
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<div class="flex flex-col gap-2">
    <!-- Render dynamically generated code -->
    <div>
        <InfiniCodeBlock Content="@GetSource()"/>
    </div>

    <!-- Render actual child content -->
    <div>
        @ChildContent
    </div>
</div>

@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private string GetSource() {
        if (ChildContent == null) return string.Empty;

        // Render the RenderFragment into the RenderTreeBuilder
        var builder = new RenderTreeBuilder();
        ChildContent.Invoke(builder);

        ArrayRange<RenderTreeFrame> frames = builder.GetFrames();
        return ProcessFrames(frames);
    }

    private static string ProcessFrames(ArrayRange<RenderTreeFrame> frames) {
        var sb = new StringBuilder();
        ProcessFrame(frames, 0, sb, 0, frames.Count);
        return sb.ToString();
    }

    private static int ProcessFrame(ArrayRange<RenderTreeFrame> frames, int startIndex, StringBuilder sb, int depth, int limit) {
        int framesProcessed = 0;

        for (int i = startIndex; framesProcessed < limit; i++, framesProcessed++) {
            RenderTreeFrame frame = frames.Array[i];

            switch (frame.FrameType) {
                case RenderTreeFrameType.Element:
                    // Render the element
                    sb.Append(new string(' ', depth * 2));
                    sb.Append($"<{frame.ElementName}");

                    // Process its attributes
                    i = ProcessAttributes(frames, i + 1, sb);

                    sb.AppendLine(">");

                    // Process child frames recursively
                    depth++;
                    i = ProcessFrame(frames, i + 1, sb, depth, frame.ElementSubtreeLength - 1);
                    depth--;

                    sb.AppendLine(new string(' ', depth * 2) + $"</{frame.ElementName}>");
                    break;

                case RenderTreeFrameType.Text:
                    // Render text content
                    sb.AppendLine(new string(' ', depth * 2) + frame.TextContent);
                    break;

                case RenderTreeFrameType.Component:
                    // Render the component
                    sb.Append(new string(' ', depth * 2));
                    sb.Append($"<{frame.ComponentType.Name}");

                    // Check for and render child content/RenderFragment attributes
                    i = ProcessAttributes(frames, i + 1, sb, depth);

                    // Check if the component has child content
                    if (frame.ComponentSubtreeLength > 0) {
                        sb.AppendLine(">");

                        // Process child frames recursively
                        depth++;
                        i = ProcessFrame(frames, i + 1, sb, depth, frame.ComponentSubtreeLength - 1);
                        depth--;

                        sb.AppendLine(new string(' ', depth * 2) + $"</{frame.ComponentType.Name}>");
                    } else {
                        sb.AppendLine(" />");
                    }

                    break;

                case RenderTreeFrameType.Markup:
                    // Handle predefined HTML markup
                    sb.AppendLine(new string(' ', depth * 2) + frame.MarkupContent);
                    break;

                case RenderTreeFrameType.Region:
                    // Process regions recursively
                    i = ProcessFrame(frames, i + 1, sb, depth, frame.RegionSubtreeLength);
                    break;

                    }
        }

        return startIndex + framesProcessed - 1;
    }

    private static int ProcessAttributes(ArrayRange<RenderTreeFrame> frames, int currentIndex, StringBuilder sb, int depth = 0) {
        while (currentIndex < frames.Count) {
            RenderTreeFrame frame = frames.Array[currentIndex];

            if (frame.FrameType == RenderTreeFrameType.Attribute) {
                if (frame.AttributeValue is RenderFragment renderFragment) {
                    // Handle RenderFragment attributes (e.g., ChildContent)
                    sb.AppendLine(">");// Close the component opening tag before rendering RenderFragment content
                    var childBuilder = new RenderTreeBuilder();

                    // Invoke the RenderFragment
                    renderFragment.Invoke(childBuilder);

                    // Process the RenderFragment's child frames
                    ArrayRange<RenderTreeFrame> childFrames = childBuilder.GetFrames();
                    ProcessFrame(childFrames, 0, sb, depth + 1, childFrames.Count);

                    sb.Append(new string(' ', depth * 2));// Indentation for closing tag
                } else {
                    // Render regular attributes
                    sb.Append($" {frame.AttributeName}=\"{frame.AttributeValue}\"");
                }

                currentIndex++;
            } else {
                // Stop processing when the next frame is not an attribute
                break;
            }
        }

        return currentIndex - 1;// Return the last processed attribute index
    }
}
