@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@using InfiniLore.InfiniBlazor.Markdown
@using InfiniLore.InfiniBlazor.TextEditor
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@page "/markdown-dual"
@rendermode InteractiveAuto
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<InfiniPage Title="Markdown Editor" Class="py-4">
    <InfiniSection Class="grow flex flex-col gap-2 overflow-auto infini-scrollbar h-128">
        <InfiniHeading1>Markdown Editor Example</InfiniHeading1>
        <InfiniMarkdownEditor @bind-Source="@TextSource0"/>
    </InfiniSection>

    <InfiniSection Class="flex flex-col gap-2 overflow-auto infini-scrollbar h-128">
        <InfiniHeading1>Markdown Editor Example</InfiniHeading1>
        <InfiniMarkdownEditor @bind-Source="@TextSource1" ShowSidePreview="@false"/>
    </InfiniSection>
</InfiniPage>
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@
@code {
    private ITextSource TextSource0 { get; set; } = new TextSource();
    private ITextSource TextSource1 { get; set; } = new TextSource {
        Text = "Some Initial text..."
    };
}

