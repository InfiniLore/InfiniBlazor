@using InfiniLore.InfiniBlazor
@inherits LayoutComponentBase
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<InfiniThemeManager/>
<InfiniToastManager/>

<InfiniLayoutContainer Layout="@NavLayout.LeftPrimary">
    <Left>
        <SideNav Location="NavLayoutLocation.Left"/>
    </Left>
    
    <Top>
        <TopNav Location="NavLayoutLocation.Top" Size="Size.Xxs"/>
    </Top>
    
    <Bottom>
        <TopNav Location="NavLayoutLocation.Bottom" Size="Size.Xxs"/>
    </Bottom>
    
    @* <Right> *@
    @*     <SideNav Location="NavLayoutLocation.Right"/> *@
    @* </Right> *@
    
    <Body>
        @Body
    </Body>
</InfiniLayoutContainer>

<div id="blazor-error-ui" class="hidden fixed bottom-0 left-0 w-full bg-yellow-100 shadow-md z-[1000] p-3 pl-5">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss cursor-pointer absolute right-3 top-2">🗙</a>
</div>

