@using InfiniLore.InfiniBlazor
@inherits LayoutComponentBase
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<InfiniThemeManager/>
<InfiniToastManager/>

<InfiniLayoutContainer Layout="NavLayout.SidesPrimary">
    <Left>
        <NavBarLeft/>
    </Left>
    
    <Top>
        <NavBarTop/>
    </Top>
    
    <Bottom>
        <NavBarBottom/>
    </Bottom>
    
    <Right>
        <NavBarRight/>
    </Right>
    
    <Body>
        @Body
    </Body>
</InfiniLayoutContainer>

<div id="blazor-error-ui" class="hidden fixed bottom-0 left-0 w-full bg-yellow-100 shadow-md p-3 pl-5 @ZIndex.BlazorError">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss cursor-pointer absolute right-3 top-2">🗙</a>
</div>

