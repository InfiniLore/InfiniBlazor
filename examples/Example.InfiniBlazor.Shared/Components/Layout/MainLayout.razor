@using InfiniLore.InfiniBlazor
@inherits LayoutComponentBase
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<InfiniThemeManager/>
<InfiniToastManager/>

<InfiniLayoutContainer Layout="NavLayout.SidesPrimary">
    <Left>
        <TopNav Location="NavLayoutLocation.Left" Orientation="Orientation.Vertical"/>
    </Left>
    
    <Top>
        <TopNav Location="NavLayoutLocation.Top" Orientation="Orientation.Horizontal"/>
    </Top>
    
    <Bottom>
        <TopNav Location="NavLayoutLocation.Bottom" Orientation="Orientation.Horizontal"/>
    </Bottom>
    
    <Right>
        <TopNav Location="NavLayoutLocation.Right" Orientation="Orientation.Vertical"/>
    </Right>
    
    <Body>
        @Body
    </Body>
</InfiniLayoutContainer>

<div id="blazor-error-ui" class="hidden fixed bottom-0 left-0 w-full bg-yellow-100 shadow-md z-[1000] p-3 pl-5">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss cursor-pointer absolute right-3 top-2">🗙</a>
</div>

