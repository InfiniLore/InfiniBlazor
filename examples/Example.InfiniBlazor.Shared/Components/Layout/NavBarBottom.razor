@* ------------------------------------------------------------------------------------------------------------------ *@
@* Imports
@* ------------------------------------------------------------------------------------------------------------------ *@
@using InfiniLore.InfiniBlazor

@* ------------------------------------------------------------------------------------------------------------------ *@
@* Descriptors
@* ------------------------------------------------------------------------------------------------------------------ *@
@rendermode InteractiveAuto
@inherits InfiniNavBase
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Html
@* ------------------------------------------------------------------------------------------------------------------ *@
<InfiniNavBar Location="NavLayoutLocation.Top" Orientation="Orientation.Horizontal" Size="Size.Xs" Class="@Class" @bind-NavBarCollapsed="CollapsedState">
    <InfiniNavLink Href="/table" IconName="@LucideNames.Table">
        <Text>Table</Text>
    </InfiniNavLink>
</InfiniNavBar>
@* ------------------------------------------------------------------------------------------------------------------ *@
@* Code
@* ------------------------------------------------------------------------------------------------------------------ *@
@code {
    [Parameter] public bool CollapsedState { get; set; }
}